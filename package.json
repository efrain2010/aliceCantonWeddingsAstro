{
  "name": "alice-canton-weddings-astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "pnpm run build && wrangler dev",
    "pages:dev": "pnpm run build && wrangler pages dev ./dist",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "prettier": "prettier . --write",
    "eslint": "eslint src/**/*.{js,astro}",
    "eslint:fix": "eslint src/**/*.{js,astro} --fix",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "dependencies": {
    "mimetext": "^3.0.27",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/cloudflare": "12",
    "@fontsource/great-vibes": "^5.2.8",
    "@fontsource/lato": "^5.2.7",
    "@fontsource/playfair-display": "^5.2.8"
  },
  "devDependencies": {
    "@astrojs/ts-plugin": "^1.10.9",
    "@cloudflare/workers-types": "^4.20251008.0",
    "@tailwindcss/vite": "^4.1.6",
    "@typescript-eslint/parser": "^8.62.0",
    "astro": "^5.7.10",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "prettier": "3.9.0",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.1.6",
    "vitest": "^4.1.6",
    "wrangler": "^4.105.0"
  }
}
