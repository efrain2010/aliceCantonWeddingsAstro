---
import {
  translations,
  routes,
  getLang,
  getPageKey,
  type Lang,
  type PageKey,
} from "../i18n/index";

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const lang: Lang = getLang(Astro.url.pathname);
const pageKey: PageKey = getPageKey(Astro.url.pathname);
const t = translations[lang];
const r = routes[lang];
const altLang: Lang = lang === "es" ? "en" : "es";
const altUrl = routes[altLang][pageKey];

const navItems = [
  { href: r.home, label: t.nav.home, key: "home" as PageKey },
  { href: r.about, label: t.nav.about, key: "about" as PageKey },
  { href: r.services, label: t.nav.services, key: "services" as PageKey },
  { href: r.venues, label: t.nav.venues, key: "venues" as PageKey },
  { href: r.gallery, label: t.nav.gallery, key: "gallery" as PageKey },
  { href: r.contact, label: t.nav.contact, key: "contact" as PageKey },
];
---

<header
  class="absolute inset-x-0 top-0 z-50 bg-gradient-to-b from-black/45 to-transparent"
>
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href={r.home} class="group flex items-center">
      <img
        src="/images/wedding-planner-alice-canton-logotipo.png"
        alt={`${t.header.logoText} — Weddings & Events`}
        class="h-12 w-auto object-contain"
      />
    </a>

    <!-- Desktop nav -->
    <div class="hidden items-center gap-6 md:flex">
      <ul class="m-0 flex list-none items-center p-0">
        {
          navItems.map((link, i) => {
            const isActive = pageKey === link.key;
            return (
              <li class="flex items-center">
                {i > 0 && (
                  <span
                    class="mx-3 text-white/40 select-none"
                    aria-hidden="true"
                  >
                    |
                  </span>
                )}
                <a
                  href={link.href}
                  class={`hover:text-gold text-xs tracking-widest uppercase transition-colors ${
                    isActive
                      ? "text-gold border-gold border-b pb-0.5"
                      : "text-white"
                  }`}
                >
                  {link.label}
                </a>
              </li>
            );
          })
        }
      </ul>
      <!-- Language switcher -->
      <a
        href={altUrl}
        class="border-gold text-gold hover:bg-gold border px-2 py-0.5 text-xs tracking-widest uppercase transition-all duration-300 hover:text-white"
        aria-label={altLang === "en"
          ? "Switch to English"
          : "Cambiar a Español"}
      >
        {t.header.langSwitch}
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="relative z-[70] flex h-8 w-8 flex-col items-center justify-center gap-1.5 md:hidden"
      aria-label={t.header.mobileMenuLabel}
      data-label-open={t.header.mobileMenuLabel}
      data-label-close={t.header.mobileMenuCloseLabel}
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="hamburger-line hamburger-line-1 block h-0.5 w-6 bg-white"
      ></span>
      <span class="hamburger-line hamburger-line-2 block h-0.5 w-6 bg-white"
      ></span>
      <span
        class="hamburger-line hamburger-line-3 block h-0.5 w-4 self-end bg-white"
      ></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-[60] flex flex-col justify-center overflow-hidden bg-charcoal px-10 md:hidden"
  >
    <span
      aria-hidden="true"
      class="font-script pointer-events-none absolute -top-4 -right-2 text-[9rem] leading-none text-white/5 select-none"
    >
      AC
    </span>
    <ul class="relative m-0 flex list-none flex-col gap-1 p-0">
      {
        navItems.map((link, i) => {
          const isActive = pageKey === link.key;
          return (
            <li
              class="menu-link overflow-hidden"
              style={`transition-delay:${120 + i * 70}ms`}
            >
              <a
                href={link.href}
                class="group flex items-baseline gap-3 py-2.5"
              >
                <span class="text-gold font-sans text-xs tracking-widest">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <span
                  class={`font-serif text-3xl tracking-wide uppercase transition-colors group-hover:text-gold sm:text-4xl ${
                    isActive ? "text-gold" : "text-white"
                  }`}
                >
                  {link.label}
                </span>
              </a>
            </li>
          );
        })
      }
      <li
        class="menu-link mt-6"
        style={`transition-delay:${120 + navItems.length * 70}ms`}
      >
        <a
          href={altUrl}
          class="border-gold text-gold hover:bg-gold inline-block border px-4 py-2 text-xs tracking-widest uppercase transition-all duration-300 hover:text-white"
        >
          {t.header.langSwitch}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  const setOpen = (open: boolean) => {
    menu?.classList.toggle("is-open", open);
    toggle?.classList.toggle("is-open", open);
    toggle?.setAttribute("aria-expanded", String(open));
    toggle?.setAttribute(
      "aria-label",
      (open ? toggle.dataset.labelClose : toggle.dataset.labelOpen) ?? "",
    );
    document.documentElement.classList.toggle("overflow-hidden", open);
  };

  toggle?.addEventListener("click", () => {
    setOpen(!menu?.classList.contains("is-open"));
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => setOpen(false));
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") setOpen(false);
  });
</script>
