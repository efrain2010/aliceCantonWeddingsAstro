---
import { translations, routes, getLang, getPageKey, type Lang, type PageKey } from '../i18n/index';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const lang: Lang = getLang(Astro.url.pathname);
const pageKey: PageKey = getPageKey(Astro.url.pathname);
const t = translations[lang];
const r = routes[lang];
const altLang: Lang = lang === 'es' ? 'en' : 'es';
const altUrl = routes[altLang][pageKey];

const navItems = [
  { href: r.home, label: t.nav.home, key: 'home' as PageKey },
  { href: r.about, label: t.nav.about, key: 'about' as PageKey },
  { href: r.services, label: t.nav.services, key: 'services' as PageKey },
  { href: r.venues, label: t.nav.venues, key: 'venues' as PageKey },
  { href: r.gallery, label: t.nav.gallery, key: 'gallery' as PageKey },
  { href: r.contact, label: t.nav.contact, key: 'contact' as PageKey },
];
---

<header class="bg-white shadow-sm sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href={r.home} class="flex flex-col items-start group leading-none">
      <span class="font-serif italic text-2xl text-charcoal tracking-wide group-hover:text-gold transition-colors">
        {t.header.logoText}
      </span>
      <span class="text-[9px] tracking-[0.28em] text-gray-400 uppercase font-light mt-0.5">
        Weddings &amp; Events
      </span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6">
      <ul class="flex items-center list-none m-0 p-0">
        {navItems.map((link, i) => {
          const isActive = pageKey === link.key;
          return (
            <li class="flex items-center">
              {i > 0 && <span class="text-gray-300 mx-3 select-none" aria-hidden="true">|</span>}
              <a
                href={link.href}
                class={`text-xs uppercase tracking-widest transition-colors hover:text-gold ${
                  isActive ? 'text-gold border-b border-gold pb-0.5' : 'text-charcoal'
                }`}
              >
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
      <!-- Language switcher -->
      <a
        href={altUrl}
        class="text-xs uppercase tracking-widest border border-gold text-gold px-2 py-0.5 hover:bg-gold hover:text-white transition-all duration-300"
        aria-label={altLang === 'en' ? 'Switch to English' : 'Cambiar a Español'}
      >
        {t.header.langSwitch}
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" class="md:hidden p-2 text-charcoal" aria-label={t.header.mobileMenuLabel}>
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100">
    <ul class="px-6 py-4 flex flex-col gap-4 list-none m-0 p-0 pl-6 pb-4 pt-4">
      {navItems.map(link => (
        <li>
          <a href={link.href} class="block text-xs uppercase tracking-widest text-charcoal hover:text-gold transition-colors py-1">
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href={altUrl}
          class="inline-block text-xs uppercase tracking-widest border border-gold text-gold px-3 py-1 hover:bg-gold hover:text-white transition-all duration-300 mt-1"
        >
          {t.header.langSwitch}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
