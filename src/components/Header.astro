---
import {
  translations,
  routes,
  getLang,
  getPageKey,
  type Lang,
  type PageKey,
} from "../i18n/index";

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const lang: Lang = getLang(Astro.url.pathname);
const pageKey: PageKey = getPageKey(Astro.url.pathname);
const t = translations[lang];
const r = routes[lang];
const altLang: Lang = lang === "es" ? "en" : "es";
const altUrl = routes[altLang][pageKey];

const navItems = [
  { href: r.home, label: t.nav.home, key: "home" as PageKey },
  { href: r.about, label: t.nav.about, key: "about" as PageKey },
  { href: r.services, label: t.nav.services, key: "services" as PageKey },
  { href: r.venues, label: t.nav.venues, key: "venues" as PageKey },
  { href: r.gallery, label: t.nav.gallery, key: "gallery" as PageKey },
  { href: r.contact, label: t.nav.contact, key: "contact" as PageKey },
];
---

<header
  class="absolute inset-x-0 top-0 z-50 bg-gradient-to-b from-black/45 to-transparent"
>
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href={r.home} class="group flex items-center">
      <img
        src="/images/wedding-planner-alice-canton-logotipo.png"
        alt={`${t.header.logoText} — Weddings & Events`}
        class="h-12 w-auto object-contain"
      />
    </a>

    <!-- Desktop nav -->
    <div class="hidden items-center gap-6 md:flex">
      <ul class="m-0 flex list-none items-center p-0">
        {
          navItems.map((link, i) => {
            const isActive = pageKey === link.key;
            return (
              <li class="flex items-center">
                {i > 0 && (
                  <span
                    class="mx-3 text-white/40 select-none"
                    aria-hidden="true"
                  >
                    |
                  </span>
                )}
                <a
                  href={link.href}
                  class={`hover:text-gold text-xs tracking-widest uppercase transition-colors ${
                    isActive
                      ? "text-gold border-gold border-b pb-0.5"
                      : "text-white"
                  }`}
                >
                  {link.label}
                </a>
              </li>
            );
          })
        }
      </ul>
      <!-- Language switcher -->
      <a
        href={altUrl}
        class="border-gold text-gold hover:bg-gold border px-2 py-0.5 text-xs tracking-widest uppercase transition-all duration-300 hover:text-white"
        aria-label={altLang === "en"
          ? "Switch to English"
          : "Cambiar a Español"}
      >
        {t.header.langSwitch}
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="p-2 text-white md:hidden"
      aria-label={t.header.mobileMenuLabel}
    >
      <svg
        class="h-6 w-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-gray-100 bg-white md:hidden"
  >
    <ul class="m-0 flex list-none flex-col gap-4 p-0 px-6 py-4 pt-4 pb-4 pl-6">
      {
        navItems.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-charcoal hover:text-gold block py-1 text-xs tracking-widest uppercase transition-colors"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li>
        <a
          href={altUrl}
          class="border-gold text-gold hover:bg-gold mt-1 inline-block border px-3 py-1 text-xs tracking-widest uppercase transition-all duration-300 hover:text-white"
        >
          {t.header.langSwitch}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => menu?.classList.toggle("hidden"));
</script>
