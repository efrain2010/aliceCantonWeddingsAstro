---
import { translations, routes, getLang, type Lang } from '../i18n/index';

const year = new Date().getFullYear();
const lang: Lang = getLang(Astro.url.pathname);
const t = translations[lang];
const r = routes[lang];
const tf = t.footer;
---

<footer class="bg-charcoal text-white">
  <div class="max-w-6xl mx-auto px-6 py-14 grid grid-cols-1 md:grid-cols-4 gap-10">
    <!-- Brand -->
    <div>
      <p class="font-serif text-xl text-gold mb-2">Alice Cantón</p>
      <p class="text-gray-400 text-sm leading-relaxed mb-5">{tf.tagline1}<br />{tf.tagline2}</p>
      <div class="flex gap-4">
        <a href="https://facebook.com/Alice-Canton-Weddings-Events" target="_blank" rel="noopener noreferrer" aria-label="Facebook"
          class="text-gray-400 hover:text-gold transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" />
          </svg>
        </a>
        <a href="https://instagram.com/alicecantonweddings" target="_blank" rel="noopener noreferrer" aria-label="Instagram"
          class="text-gray-400 hover:text-gold transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Contact -->
    <div>
      <h4 class="font-serif text-base mb-4 text-gold">{tf.contactHeading}</h4>
      <ul class="text-gray-400 text-sm space-y-2">
        <li>
          <a href="tel:9992928921" class="hover:text-gold transition-colors">999 292 8921</a>
        </li>
        <li>
          <a href="mailto:alicecantonweddings@gmail.com" class="hover:text-gold transition-colors">alicecantonweddings@gmail.com</a>
        </li>
        <li class="leading-relaxed">Calle 59D #253 x 122 y 124c,<br />Yucalpetén, Mérida, Yuc.</li>
      </ul>
    </div>

    <!-- Quick links -->
    <div>
      <h4 class="font-serif text-base mb-4 text-gold">{tf.linksHeading}</h4>
      <ul class="text-gray-400 text-sm space-y-2">
        {tf.links.map(link => (
          <li>
            <a href={r[link.pageKey]} class="hover:text-gold transition-colors">{link.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Specialties -->
    <div>
      <h4 class="font-serif text-base mb-4 text-gold">{tf.specialtiesHeading}</h4>
      <ul class="text-gray-400 text-sm space-y-2">
        {tf.specialties.map(s => (
          <li>
            <a href={r[s.pageKey]} class="hover:text-gold transition-colors">{s.label}</a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="border-t border-gray-700 py-4 text-center text-gray-500 text-xs">
    © {year} {tf.copyrightSuffix}
  </div>
</footer>
