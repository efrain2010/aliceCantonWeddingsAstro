---
import { translations, routes, getLang, type Lang } from "../i18n/index";
import { CONTACT, phoneHref, emailHref } from "../config/site";

const year = new Date().getFullYear();
const lang: Lang = getLang(Astro.url.pathname);
const t = translations[lang];
const r = routes[lang];
const tf = t.footer;
---

<footer class="bg-charcoal text-white">
  <div
    class="mx-auto grid max-w-6xl grid-cols-1 gap-10 px-6 py-14 md:grid-cols-4"
  >
    <!-- Brand -->
    <div>
      <p class="text-gold mb-2 font-serif text-xl">Alice Cantón</p>
      <p class="mb-5 text-sm leading-relaxed text-gray-400">
        {tf.tagline1}<br />{tf.tagline2}
      </p>
      <div class="flex gap-4">
        <a
          href="https://facebook.com/Alice-Canton-Weddings-Events"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="hover:text-gold text-gray-400 transition-colors"
        >
          <svg
            class="h-5 w-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"
            ></path>
          </svg>
        </a>
        <a
          href="https://instagram.com/alicecantonweddings"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="hover:text-gold text-gray-400 transition-colors"
        >
          <svg
            class="h-5 w-5"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <circle cx="12" cy="12" r="4"></circle>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"
            ></circle>
          </svg>
        </a>
      </div>
    </div>

    <!-- Contact -->
    <div>
      <h4 class="text-gold mb-4 font-serif text-base">{tf.contactHeading}</h4>
      <ul class="space-y-2 text-sm text-gray-400">
        <li>
          <a href={phoneHref} class="hover:text-gold transition-colors"
            >{CONTACT.phone}</a
          >
        </li>
        <li>
          <a href={emailHref} class="hover:text-gold transition-colors"
            >{CONTACT.email}</a
          >
        </li>
        <li class="leading-relaxed">
          Calle 59D #253 x 122 y 124c,<br />Yucalpetén, Mérida, Yuc.
        </li>
      </ul>
    </div>

    <!-- Quick links -->
    <div>
      <h4 class="text-gold mb-4 font-serif text-base">{tf.linksHeading}</h4>
      <ul class="space-y-2 text-sm text-gray-400">
        {
          tf.links.map((link) => (
            <li>
              <a
                href={r[link.pageKey]}
                class="hover:text-gold transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Specialties -->
    <div>
      <h4 class="text-gold mb-4 font-serif text-base">
        {tf.specialtiesHeading}
      </h4>
      <ul class="space-y-2 text-sm text-gray-400">
        {
          tf.specialties.map((s) => (
            <li>
              <a href={r[s.pageKey]} class="hover:text-gold transition-colors">
                {s.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="border-t border-gray-700 py-4 text-center text-xs text-gray-500">
    © {year}
    {tf.copyrightSuffix}
  </div>
</footer>
