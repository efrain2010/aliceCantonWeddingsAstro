---
interface Props {
  title: string;
  subtitle?: string;
  cta?: { label: string; href: string };
  imageSrc?: string;
  height?: "full" | "medium" | "small";
}

const { title, subtitle, cta, imageSrc, height = "medium" } = Astro.props;

const heightClass = {
  full: "min-h-screen",
  medium: "min-h-[65vh]",
  small: "min-h-[40vh]",
}[height];
---

<section
  style={imageSrc
    ? `background-image: url('${imageSrc}'); background-size: cover; background-position: center; background-attachment: fixed;`
    : "background: linear-gradient(135deg, #2C2C2C 0%, #3d2e22 60%, #7a5c3a 100%);"}
  class={`relative flex items-center justify-center text-center pt-[80px] ${heightClass}`}
>
  <div class="absolute inset-0 bg-black/45"></div>
  <div class="relative z-10 mx-auto max-w-3xl px-6">
    <h1 class="mb-6 font-serif text-4xl leading-tight text-white md:text-6xl">
      {title}
    </h1>
    {
      subtitle && (
        <p class="mb-10 text-lg leading-relaxed text-white/85 md:text-xl">
          {subtitle}
        </p>
      )
    }
    {
      cta && (
        <a
          href={cta.href}
          class="border-gold text-gold hover:bg-gold inline-block border-2 px-10 py-3 text-xs font-medium tracking-widest uppercase transition-all duration-300 hover:text-white"
        >
          {cta.label}
        </a>
      )
    }
  </div>
</section>
