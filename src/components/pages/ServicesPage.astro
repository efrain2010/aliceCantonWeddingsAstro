---
import { getImage } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import { getLang, useTranslations } from "../../i18n/index";
import ContactForm from "../ContactForm.astro";
import HeroImage from "../HeroImage.astro";
import heroTablescape from "../../assets/services/aerial-rustic-table-toast-bride-groom-cards.jpg";
import packagesIntroBg from "../../assets/services/garden-dessert-table-teal-lights-night.jpg";
import contactParallaxBg from "../../assets/services/wicker-wreath-centerpiece-gold-rim-glasses.jpg";

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const p = t.pages.services;

// Full-bleed CSS backgrounds can't use <Image>, so pre-optimize via getImage()
const heroTablescapeOptimized = await getImage({
  src: heroTablescape,
  width: 900,
  format: "webp",
  quality: 40,
});
const packagesIntroOptimized = await getImage({
  src: packagesIntroBg,
  width: 960,
  format: "webp",
});
const contactParallaxOptimized = await getImage({
  src: contactParallaxBg,
  width: 1920,
  format: "webp",
});
---

<Layout description={p.meta.description} title={p.meta.title}>
  <HeroImage heroImage={heroTablescapeOptimized.src} title={p.hero.title} />

  <!-- ② STRENGTHS: 4 left-aligned columns on white, no cards -->
  <section class="bg-white py-20">
    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-10 px-6 md:grid-cols-4">
      {
        p.values.map((v) => (
          <div>
            <img alt="" class="mb-6 h-12 w-auto" src={`/images/${v.icon}`} />
            <h2
              class="text-heading-gray mb-4 font-serif text-2xl"
              style="font-variant: small-caps;"
            >
              {v.title}
            </h2>
            <p class="text-body-gray text-base leading-relaxed">{v.text}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ③ PACKAGES INTRO: split photo / teal block -->
  <section class="grid grid-cols-1 md:grid-cols-2">
    <div
      aria-label={p.packagesIntro.title}
      class="min-h-[320px] bg-cover bg-center md:min-h-[400px]"
      role="img"
      style={`background-image: url('${packagesIntroOptimized.src}');`}
    >
    </div>
    <div class="bg-teal-bg flex flex-col justify-center px-10 py-16 md:px-14">
      <h2
        class="mb-4 font-serif text-3xl text-white md:text-4xl"
        style="font-variant: small-caps;"
      >
        {p.packagesIntro.title}
      </h2>
      <div class="mb-8 w-40 border-b border-white/60"></div>
      <p class="text-base leading-loose text-white">
        {p.packagesIntro.text}
      </p>
    </div>
  </section>

  <!-- ④ PACKAGES: title + 3 centered columns on white -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h2
        class="text-heading-gray mb-20 text-center font-serif text-5xl md:text-6xl"
        style="font-variant: small-caps;"
      >
        {p.packagesTitle}
      </h2>
      <div class="grid grid-cols-1 gap-12 md:grid-cols-3">
        {
          p.packages.map((pkg) => (
            <div class="flex flex-col items-center text-center">
              <img
                alt=""
                class="mb-6 h-10 w-auto"
                src={`/images/${pkg.icon}`}
              />
              <h3
                class="text-heading-gray mb-8 font-serif text-4xl leading-tight"
                style="font-variant: small-caps;"
              >
                {pkg.title}
              </h3>
              <p class="text-body-gray mb-10 flex-1 text-base leading-loose">
                {pkg.text}
              </p>
              <a
                class="bg-teal-bg inline-block px-7 py-4 text-sm text-white transition-opacity hover:opacity-90"
                href="#form"
              >
                {pkg.cta}
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ⑤ SOCIAL: follow us icons -->
  <section class="bg-white pt-6 pb-20 text-center">
    <div class="mx-auto max-w-4xl px-6">
      <h2
        class="text-heading-gray mb-2 font-serif text-3xl"
        style="font-variant: small-caps;"
      >
        {p.social.title}
      </h2>
      <h3
        class="text-heading-gray mb-10 font-serif text-3xl"
        style="font-variant: small-caps;"
      >
        {p.social.subtitle}
      </h3>
      <div class="flex justify-center gap-16">
        <a
          aria-label="Facebook"
          class="inline-flex h-14 w-14 items-center justify-center border border-gray-200 transition-colors hover:border-gray-400"
          href="https://www.facebook.com/Alice-Canton-Weddings-Events-545462678924715/"
          rel="noopener noreferrer"
          target="_blank"
        >
          <img
            alt=""
            class="h-7 w-7 opacity-60"
            src="/images/social-icon-2.png"
          />
        </a>
        <a
          aria-label="Instagram"
          class="inline-flex h-14 w-14 items-center justify-center border border-gray-200 transition-colors hover:border-gray-400"
          href="https://www.instagram.com/alicecantonweddings/"
          rel="noopener noreferrer"
          target="_blank"
        >
          <img
            alt=""
            class="h-7 w-7 opacity-60"
            src="/images/instagram-logo.png"
          />
        </a>
      </div>
    </div>
  </section>

  <!-- ⑥ CONTACT: light parallax background with inset white card -->
  <section
    class="relative bg-cover bg-scroll bg-center py-24 md:bg-fixed"
    id="form"
    style={`background-image: url('${contactParallaxOptimized.src}');`}
  >
    <div class="relative mx-auto max-w-5xl px-6">
      <div
        class="grid grid-cols-1 gap-12 bg-white px-10 py-16 md:grid-cols-5 md:px-16"
      >
        <!-- Left: heading + text -->
        <div class="md:col-span-2">
          <h2
            class="text-heading-gray mb-8 font-serif text-4xl leading-tight md:text-5xl"
            style="font-variant: small-caps;"
          >
            {p.contact.title}
          </h2>
          <p class="text-body-gray text-base leading-loose">
            {p.contact.text}
          </p>
        </div>
        <!-- Right: form -->
        <div class="md:col-span-3">
          <ContactForm bare />
        </div>
      </div>
    </div>
  </section>
</Layout>
