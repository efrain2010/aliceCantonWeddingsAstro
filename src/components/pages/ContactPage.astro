---
import { getImage } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import ContactForm from "../ContactForm.astro";
import SectionCTA from "../SectionCTA.astro";
import { getLang, useTranslations } from "../../i18n/index";
import { phoneHref } from "../../config/site";
import HeroImage from "../HeroImage.astro";
import heroTableSetting from "../../assets/contact/bride-hand-engagement-ring-place-card-table-setting.jpg";

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const p = t.pages.contact;
const l = p.labels;

const mapSrc =
  "https://maps.google.com/maps?q=Alice%20Cant%C3%B3n%20Weddings%20Events%20Calle%2059D%20Yucalpet%C3%A9n%20M%C3%A9rida&t=&z=14&ie=UTF8&iwloc=&output=embed";

// Full-bleed CSS backgrounds can't use <Image>, so pre-optimize via getImage()
const heroTableSettingOptimized = await getImage({
  src: heroTableSetting,
  width: 1366,
  format: "webp",
});
---

<Layout description={p.meta.description} title={p.meta.title}>
  <HeroImage heroImage={heroTableSettingOptimized.src} title={p.hero.title} />

  <!-- ② FORM + CONTACT INFO -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-1 gap-12 md:grid-cols-2 md:gap-16">
        <!-- Left: Agenda una Cita + form -->
        <div>
          <h2
            class="text-charcoal mb-6 font-serif text-4xl"
            style="font-variant: small-caps;"
          >
            {l.scheduleTitle}
          </h2>
          <p class="mb-6 text-sm text-gray-500">{l.formNote}</p>
          <ContactForm
            bare={true}
            showDate={false}
            singleColumn={true}
            submitLabel={lang === "es" ? "Enviar" : "Send"}
          />
        </div>

        <!-- Right: Contacto info + map -->
        <div>
          <h2
            class="text-charcoal mb-6 font-serif text-4xl"
            style="font-variant: small-caps;"
          >
            {l.contactTitle}
          </h2>
          <div class="mb-8 space-y-3 text-gray-600">
            <p>
              <span class="text-charcoal font-semibold">{l.addressLabel}:</span>
              {l.address}
            </p>
            <p>
              <span class="text-charcoal font-semibold">{l.phoneLabel}:</span>{
                " "
              }
              <a class="text-gold hover:underline" href={phoneHref}>{l.phone}</a
              >
            </p>
            <p>
              <span class="text-charcoal font-semibold">{l.emailLabel}:</span>{
                " "
              }
              <a
                class="text-gold break-all hover:underline"
                href={`mailto:${l.email}`}>{l.email}</a
              >
            </p>
          </div>
          <div class="overflow-hidden border border-gray-200">
            <iframe
              height="300"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              src={mapSrc}
              style="border:0;"
              title="Alice Cantón Weddings & Events"
              width="100%"></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ③ FAQ: two-column open Q&A -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-12 text-center">
        <h2
          class="text-charcoal font-serif text-4xl md:text-5xl"
          style="font-variant: small-caps;"
        >
          {p.faq.title}
        </h2>
        <div class="bg-gold mx-auto mt-5 h-0.5 w-16"></div>
      </div>
      <div
        class="columns-1 gap-12 md:columns-2 [&>*]:mb-10 [&>*]:break-inside-avoid"
      >
        {
          p.faq.items.map((faq) => (
            <div>
              <h3
                class="text-charcoal mb-3 font-serif text-xl md:text-2xl"
                style="font-variant: small-caps;"
              >
                {faq.q}
              </h3>
              <p class="text-sm leading-relaxed text-gray-600">{faq.a}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ④ QUOTE BAND -->
  <section class="bg-forest px-6 py-16 text-white">
    <div class="mx-auto max-w-4xl text-center">
      <h2
        class="font-serif text-2xl leading-relaxed md:text-3xl"
        style="font-variant: small-caps;"
      >
        {p.quote}
      </h2>
    </div>
  </section>

  <SectionCTA />
</Layout>
