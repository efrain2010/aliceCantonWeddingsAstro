---
import Layout from "../../layouts/Layout.astro";
import { getLang, useTranslations } from "../../i18n/index";
import { phoneHref } from "../../config/site";
import HeroImage from "../HeroImage.astro";
import GalleryGrid from "../GalleryGrid.astro";

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const p = t.pages.gallery;
---

<Layout description={p.meta.description} title={p.meta.title}>
  <HeroImage
    heroImage="/images/guests-smartphones-bride-1024x584.jpg"
    title={p.hero.title}
  />

  <!-- ② PORTAFOLIO INTRO -->
  <section class="bg-white py-16 text-center md:py-20">
    <div class="mx-auto max-w-3xl px-6">
      <h2
        class="text-charcoal mb-6 font-serif text-4xl md:text-5xl"
        style="font-variant: small-caps;"
      >
        {p.intro.title}
      </h2>
      <p class="leading-relaxed text-gray-600" set:html={p.intro.body} />
    </div>
  </section>

  <!-- ③ MASONRY GRID -->
  <section class="bg-white pb-2">
    <GalleryGrid photos={p.photos} />
  </section>

  <!-- ④ GOLD CTA: Su Especialista en Bodas -->
  <section class="bg-gold px-6 py-16 text-center text-white">
    <h2
      class="mb-6 font-serif text-3xl md:text-4xl"
      style="font-variant: small-caps;"
    >
      {p.cta.title}
    </h2>
    <div
      class="flex flex-col items-center justify-center gap-3 text-sm tracking-wide md:flex-row md:gap-10"
    >
      <span
        >{p.cta.phoneLabel}: <a class="hover:underline" href={phoneHref}
          >{p.cta.phone}</a
        ></span
      >
      <span aria-hidden="true" class="hidden text-white/40 md:inline">|</span>
      <span
        >{p.cta.emailLabel}: <a
          class="hover:underline"
          href={`mailto:${p.cta.email}`}>{p.cta.email}</a
        ></span
      >
    </div>
  </section>
</Layout>
