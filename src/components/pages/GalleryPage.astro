---
import Layout from '../../layouts/Layout.astro';
import Hero from '../Hero.astro';
import SectionCTA from '../SectionCTA.astro';
import { getLang, routes, useTranslations } from '../../i18n/index';

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const p = t.pages.gallery;
const r = routes[lang];

const gradients = [
  'linear-gradient(135deg, #3d2e22 0%, #C9A96E 100%)',
  'linear-gradient(135deg, #2C2C2C 0%, #4a3728 100%)',
  'linear-gradient(135deg, #E8D5C4 0%, #C9A96E 100%)',
  'linear-gradient(135deg, #4a3728 0%, #3d2e22 100%)',
  'linear-gradient(135deg, #2C2C2C 0%, #C9A96E 100%)',
  'linear-gradient(135deg, #3d2e22 0%, #E8D5C4 100%)',
  'linear-gradient(135deg, #C9A96E 0%, #2C2C2C 100%)',
  'linear-gradient(135deg, #FAF7F2 0%, #C9A96E 100%)',
];
---

<Layout title={p.meta.title} description={p.meta.description}>

  <Hero title={p.hero.title} subtitle={p.hero.subtitle} height="small" />

  <section class="py-20 bg-charcoal">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-gold text-xs uppercase tracking-widest mb-3">{p.grid.label}</p>
        <h2 class="font-serif text-4xl text-white">{p.grid.title}</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 auto-rows-[200px]">
        {p.photos.map((photo, i) => (
          <div class={`overflow-hidden group cursor-pointer ${photo.span}`}>
            {photo.src
              ? (
                <img
                  src={photo.src}
                  alt={photo.alt}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                  loading="lazy"
                />
              )
              : (
                <div
                  class="w-full h-full transition-transform duration-700 group-hover:scale-110 flex items-end p-4"
                  style={`background: ${gradients[i % gradients.length]};`}
                >
                  <span class="text-white/40 text-xs uppercase tracking-widest">{photo.alt}</span>
                </div>
              )
            }
          </div>
        ))}
      </div>

      <p class="text-center text-gray-500 text-sm mt-10">
        {p.grid.ctaNote}{' '}
        <a href={r.contact} class="text-gold hover:underline">{p.grid.ctaLink}</a>
      </p>
    </div>
  </section>

  <SectionCTA />
</Layout>
