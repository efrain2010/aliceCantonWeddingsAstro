---
import Layout from "../../layouts/Layout.astro";
import { getLang, useTranslations } from "../../i18n/index";
import HeroImage from "../HeroImage.astro";

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const p = t.pages.gallery;
---

<Layout title={p.meta.title} description={p.meta.description}>
  <HeroImage
    heroImage="/images/guests-smartphones-bride-1024x584.jpg"
    title={p.hero.title}
  />

  <!-- ② PORTAFOLIO INTRO -->
  <section class="bg-white py-16 text-center md:py-20">
    <div class="mx-auto max-w-3xl px-6">
      <h2
        class="text-charcoal mb-6 font-serif text-4xl md:text-5xl"
        style="font-variant: small-caps;"
      >
        {p.intro.title}
      </h2>
      <p class="leading-relaxed text-gray-600" set:html={p.intro.body} />
    </div>
  </section>

  <!-- ③ MASONRY GRID -->
  <section class="bg-white pb-2">
    <div
      class="columns-2 gap-1.5 px-1.5 md:columns-3 lg:columns-4 [&>*]:mb-1.5"
    >
      {
        p.photos.map((photo) => (
          <div class="group break-inside-avoid overflow-hidden">
            <img
              src={photo.src}
              alt={photo.alt}
              loading="lazy"
              class="block w-full transition-transform duration-700 group-hover:scale-105"
            />
          </div>
        ))
      }
    </div>
  </section>

  <!-- ④ GOLD CTA: Su Especialista en Bodas -->
  <section class="bg-gold px-6 py-16 text-center text-white">
    <h2
      class="mb-6 font-serif text-3xl md:text-4xl"
      style="font-variant: small-caps;"
    >
      {p.cta.title}
    </h2>
    <div
      class="flex flex-col items-center justify-center gap-3 text-sm tracking-wide md:flex-row md:gap-10"
    >
      <span
        >{p.cta.phoneLabel}: <a
          href={`tel:${p.cta.phone.replace(/\s/g, "")}`}
          class="hover:underline">{p.cta.phone}</a
        ></span
      >
      <span class="hidden text-white/40 md:inline" aria-hidden="true">|</span>
      <span
        >{p.cta.emailLabel}: <a
          href={`mailto:${p.cta.email}`}
          class="hover:underline">{p.cta.email}</a
        ></span
      >
    </div>
  </section>
</Layout>
