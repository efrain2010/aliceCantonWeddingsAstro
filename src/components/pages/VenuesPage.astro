---
import Layout from "../../layouts/Layout.astro";
import SectionCTA from "../SectionCTA.astro";
import { getLang, useTranslations } from "../../i18n/index";
import HeroImage from "../HeroImage.astro";

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const p = t.pages.venues;

const heroTitle = lang === "es" ? "Locaciones" : "Venues";

// Per-category photo galleries (shared across locales)
const categoryImages = [
  ["hac-1", "hac-2", "hac-3", "hac-4", "hac-5", "hac-6", "hac-7", "hac-8"],
  ["pla-1", "pla-2", "pla-3", "pla-4", "pla-5", "pla-6"],
  ["cen-1", "cen-2", "cen-3", "cen-4", "cen-5", "cen-6", "cen-7", "cen-8"],
  ["bac-1", "bac-2"],
].map((arr) => arr.map((n) => `/images/venues/${n}.jpg`));

const content = {
  es: {
    increiblasImage: "/images/boda-playa-1024x576.jpg",
    celebracionesImage: "/images/guests-smartphones-bride-1024x584.jpg",
    increiblasTitle: "Locaciones Increíbles",
    increiblasBody:
      "Conoce las locaciones del estado de Yucatán, podemos organizar el mejor día de tu vida en haciendas, playas y lugares con los que solo has soñado. Agenda una cita y conoce salones de eventos impresionantes, haciendas antiguas y playas increíbles.",
    celebracionesTitle: "Celebraciones Inolvidables",
    celebracionesBody:
      "Dejanos ayudarte con la planeación de tu evento, te asesoramos para tener la mejor experiencia aún si ya has elegido un lugar. Haciendas, playas, cenotes, el lugar que desees nosotros te ayudamos a volverlo increíble.",
    bandTitle: "Locaciones en Mérida Yucatán",
    venueCategories: [
      {
        title: "Haciendas en Yucatán",
        description:
          "Viaja a través del tiempo y realiza tu boda en una de las majestuosas haciendas que se encuentran en Yucatán. Un lugar mágico y lleno de historia que convertirá tu gran día en un cuento de hadas.",
      },
      {
        title: "Playas Yucatecas",
        description:
          "¿Amas la playa y sueñas con tu boda frente al mar?. La costa Yucateca cuenta con playas hermosas y diferentes opciones para realizar ahí tu enlace. Elige la que más te guste para ser la sede de tu gran día y manos a la obra.",
      },
      {
        title: "Cenotes en Yucatán",
        description:
          "Cenote (del maya dzonoot: 'hoyo con agua'). Una maravilla de la naturaleza única en el mundo y tú podrías realizar tu boda en este mágico lugar. Los cenotes son lugares sagrados donde los mayas realizaban sus rituales y ceremonias. Una boda en este cenote espectacular haría tu gran día algo más que especial.",
      },
      {
        title: "Laguna de los 7 colores, Bacalar, QRoo",
        description:
          'El nombre de Bacalar viene del maya "Sian Ka\'an Bakhalal", la cual quiere decir "lugar donde nace el cielo". Imagina casarte en este paraíso. Bacalar es un pueblito con un encanto sin igual, la laguna de los 7 colores toma su nombre de las diferentes tonalidades que tiene debido a los 3 cenotes que se encuentran dentro de ella. Un regalo de la naturaleza que puede ser testigo de tu gran día.',
      },
    ],
  },
  en: {
    increiblasImage: "/images/boda-playa-1024x576.jpg",
    celebracionesImage: "/images/guests-smartphones-bride-1024x584.jpg",
    increiblasTitle: "Amazing Venues",
    increiblasBody:
      "Get to know the venues in the state of Yucatán. We can organize the best day of your life in haciendas, beaches and places you've only dreamed of. Schedule an appointment and discover impressive event halls, ancient haciendas and incredible beaches.",
    celebracionesTitle: "Unforgettable Celebrations",
    celebracionesBody:
      "Let us help you plan your event. We advise you to have the best experience even if you've already chosen a location. Haciendas, beaches, cenotes—whatever location you choose, we'll help you make it incredible.",
    bandTitle: "Venues in Mérida Yucatán",
    venueCategories: [
      {
        title: "Haciendas in Yucatán",
        description:
          "Travel through time and celebrate your wedding at one of the majestic haciendas in Yucatán. A magical place full of history that will turn your special day into a fairy tale.",
      },
      {
        title: "Yucatecan Beaches",
        description:
          "Do you love the beach and dream of your wedding by the sea? The Yucatán coast has beautiful beaches and different options to celebrate your wedding there. Choose the one you like best to be the setting for your special day and let's make it happen.",
      },
      {
        title: "Cenotes in Yucatán",
        description:
          'Cenote (from Mayan dzonoot: "water hole"). A unique wonder of nature in the world and you could celebrate your wedding in this magical place. Cenotes are sacred places where the Maya performed rituals and ceremonies. A wedding at this spectacular cenote would make your special day something truly extraordinary.',
      },
      {
        title: "Laguna de los 7 Colores, Bacalar, QRoo",
        description:
          'The name Bacalar comes from the Maya "Sian Ka\'an Bakhalal", which means "place where the sky is born". Imagine getting married in this paradise. Bacalar is a charming little town with incomparable charm, and the Laguna de los 7 Colores takes its name from the different color variations it has due to the 3 cenotes within it. A gift from nature that can witness your special day.',
      },
    ],
  },
}[lang];
---

<Layout title={p.meta.title} description={p.meta.description}>
  <HeroImage
    heroImage="/images/foxglove-spires-path-PYQPXBU-1.jpg"
    title={heroTitle}
  />

  <!-- ② TWO-COLUMN INTRO -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid grid-cols-1 gap-10 md:grid-cols-2 md:gap-12">
        <div>
          <img
            src={content.increiblasImage}
            alt={content.increiblasTitle}
            class="mb-7 h-auto w-full object-cover"
          />
          <h2
            class="text-charcoal mb-5 font-serif text-3xl md:text-4xl"
            style="font-variant: small-caps;"
          >
            {content.increiblasTitle}
          </h2>
          <p class="leading-relaxed text-gray-600">{content.increiblasBody}</p>
        </div>
        <div>
          <img
            src={content.celebracionesImage}
            alt={content.celebracionesTitle}
            class="mb-7 h-auto w-full object-cover"
          />
          <h2
            class="text-charcoal mb-5 font-serif text-3xl md:text-4xl"
            style="font-variant: small-caps;"
          >
            {content.celebracionesTitle}
          </h2>
          <p class="leading-relaxed text-gray-600">
            {content.celebracionesBody}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ③ FOREST-GREEN SECTION BAND -->
  <div class="bg-forest px-6 py-20 text-white md:py-24">
    <div class="mx-auto max-w-4xl text-center">
      <h2
        class="font-serif text-5xl leading-tight md:text-6xl"
        style="font-variant: small-caps;"
      >
        {content.bandTitle}
      </h2>
    </div>
  </div>

  <!-- ④ VENUE CATEGORIES with galleries -->
  <section class="bg-white py-16 md:py-20">
    {
      content.venueCategories.map((category, ci) => (
        <div class="mb-16 last:mb-0 md:mb-20">
          <div class="mb-10 px-6 text-center">
            <h2
              class="text-charcoal mb-5 font-serif text-4xl md:text-5xl"
              style="font-variant: small-caps;"
            >
              {category.title}
            </h2>
            <p class="mx-auto max-w-3xl text-lg leading-relaxed text-gray-600">
              {category.description}
            </p>
          </div>
          <div class="grid grid-cols-2 gap-1.5 px-1.5 md:grid-cols-4">
            {categoryImages[ci].map((src) => (
              <div class="group aspect-square overflow-hidden">
                <img
                  src={src}
                  alt={category.title}
                  loading="lazy"
                  class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                />
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </section>

  <SectionCTA />
</Layout>
