---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../ContactForm.astro';
import { getLang, routes, useTranslations } from '../../i18n/index';

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const p = t.pages.home;
const r = routes[lang];

// Background photos for the 4 category cards (Planeación, Banquete, Música, Duración)
const categoryImages = [
  '/images/img-1.jpg',
  '/images/img-3.jpg',
  '/images/gallery-2.jpg',
  '/images/img-vert-3.jpg',
];

// Portfolio teaser gallery
const portfolioImages = [
  '/images/img-10.jpg',
  '/images/img-13.jpg',
  '/images/11866446-1055970124415858-485634197070961453-n.jpg',
  '/images/12042744-677267902410858-182616168831263564-n.jpg',
  '/images/21766380-1682893168411606-8935133582193004569-n.jpg',
  '/images/22045605-1682895238411399-7185113022696085452-n.jpg',
  '/images/26114160-10155866400061278-369103440261741743-n.jpg',
  '/images/26231465-10155865148386278-3104021065434766057-n.jpg',
  '/images/hg1a5445-1024x683.jpg',
  '/images/48397507-1055284681317792-3700600962478505984-o-1024x648.jpg',
  '/images/dsc00641-1024x674.jpg',
  '/images/48244230-1056587157856808-6144760103514931200-o-1024x682.jpg',
];
---

<Layout title={p.meta.title} description={p.meta.description}>

  <!-- ① HERO: Full-width beach image with circular badge logo overlay -->
  <section class="relative min-h-screen w-full overflow-hidden -mt-[80px] pt-[80px] bg-cover bg-center bg-fixed"
    style="background-image: url('/images/hero-beach.png');"
  >
    <!-- Dark overlay for readability -->
    <div class="absolute inset-0 bg-black/40" />

    <!-- Centered circular badge logo (real asset from brand) -->
    <div class="absolute inset-0 z-10 flex items-center justify-center">
      <img
        src="/images/logo-badge.png"
        alt="Alice Cantón Weddings & Events"
        class="w-72 h-72 md:w-96 md:h-96 object-contain"
      />
    </div>
  </section>

  <!-- ② INTRO: image left + value proposition text right -->
  <section class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <!-- Image (left) -->
        <div>
          <img
            src="/images/boda-ciudad-1024x576.jpg"
            alt="Boda en Mérida Yucatán"
            class="w-full h-auto object-cover"
          />
        </div>
        <!-- Intro heading and text (right) -->
        <div class="text-center md:text-left">
          <h1 class="font-serif text-4xl md:text-5xl text-heading-gray mb-8 uppercase tracking-wide">
            {p.intro.title}
          </h1>
          <p class="text-body-gray text-lg leading-relaxed">
            {p.intro.body}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ③ CATEGORIES: 4-column grid of keyword cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 w-full">
    {p.categories.map((cat, i) => (
      <div
        class="relative h-56 overflow-hidden group bg-cover bg-center"
        style={`background-image: url('${categoryImages[i]}');`}
      >
        <div class="absolute inset-0 bg-black/40 group-hover:bg-black/25 transition-colors duration-300" />
        <div class="absolute inset-0 flex items-center justify-center">
          <span class="font-serif text-2xl text-white uppercase tracking-widest text-center px-4">
            {cat.label}
          </span>
        </div>
      </div>
    ))}
  </div>

  <!-- ④ SERVICES: Three service cards with descriptions -->
  <section class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-serif text-4xl md:text-5xl text-heading-gray text-center mb-16 uppercase tracking-wide">
        {p.services.title}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        {p.services.items.map((service) => (
          <div class="text-center">
            <h3 class="font-serif text-2xl text-heading-gray mb-6 uppercase tracking-wide">
              {service.title}
            </h3>
            <p class="text-body-gray text-base leading-relaxed">
              {service.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑤ STORY: "Nuestra Historia" with text and bouquet image -->
  <section class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
        <!-- Text column (left) -->
        <div>
          <h2 class="font-serif text-4xl md:text-5xl text-heading-gray mb-4 uppercase tracking-wide text-center">
            {p.history.title}
          </h2>
          <p class="font-serif text-sm text-heading-gray uppercase tracking-widest mb-8 text-center">
            {p.history.subtitle}
          </p>
          <div class="text-accent-gold text-3xl my-6 text-center" aria-hidden="true">◆</div>
          <p class="text-body-gray text-base leading-relaxed mb-6">
            {p.history.body1}
          </p>
          <p class="text-body-gray text-base leading-relaxed mb-8">
            {p.history.body2}
          </p>
          <a
            href={r.contact}
            class="inline-block bg-button-dark text-white px-8 py-3 font-serif uppercase tracking-widest text-sm hover:opacity-90 transition-opacity"
          >
            {p.history.cta}
          </a>
        </div>

        <!-- Image column (right) -->
        <div class="hidden md:block">
          <img
            src="/images/wedding-bouquet-pakbnhh.jpg"
            alt="Wedding bouquet"
            class="w-full h-auto object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ⑥ QUOTE BAND: standalone romantic pull-quote -->
  <section class="bg-teal-bg py-24 text-center">
    <div class="max-w-4xl mx-auto px-6">
      <blockquote class="font-serif italic text-2xl md:text-4xl text-white mb-8 leading-relaxed">
        “{p.quote.text}”
      </blockquote>
      <p class="font-serif text-sm text-accent-gold uppercase tracking-[0.25em]">
        {p.quote.attribution}
      </p>
    </div>
  </section>

  <!-- ⑦ PORTFOLIO GALLERY: uniform grid of wedding images -->
  <section class="bg-gray-900 py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-2">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
        {portfolioImages.map((src) => (
          <div class="aspect-square overflow-hidden group">
            <img
              src={src}
              alt="Wedding portfolio"
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑧ TESTIMONIALS QUOTE BAND -->
  <section class="bg-teal-bg py-16 text-center">
    <div class="max-w-4xl mx-auto px-6">
      <blockquote class="font-serif text-3xl md:text-4xl text-white mb-6 leading-relaxed italic">
        {p.quoteBand.text}
      </blockquote>
      <p class="font-serif text-lg text-white/90 uppercase tracking-widest">
        {p.quoteBand.attribution}
      </p>
    </div>
  </section>

  <!-- ⑨ TESTIMONIALS: Review cards with client feedback -->
  <section class="relative bg-cover bg-center bg-fixed py-24" style="background-image: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), url('/images/parallax-2.jpg');">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {p.testimonials.items.map((item) => (
          <div class="bg-white/95 p-8">
            <p class="text-body-gray text-base leading-relaxed mb-8 italic">
              "{item.quote}"
            </p>
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 rounded-full bg-gradient-to-br from-accent-gold to-rose flex-shrink-0 overflow-hidden">
                <div class="w-full h-full bg-accent-gold/20" />
              </div>
              <div>
                <p class="text-heading-gray text-sm uppercase font-serif tracking-wide">
                  {item.author}
                </p>
                <p class="text-body-gray text-xs">
                  {item.year}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑩ CTA BAND: Special day quote -->
  <section class="bg-teal-bg py-16 text-center">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="font-serif text-3xl md:text-4xl text-white uppercase tracking-wide leading-relaxed">
        {p.ctaBand.text}
      </h2>
    </div>
  </section>

  <!-- ⑪ CONTACT SECTION: "Platiquemos" with form -->
  <section class="bg-cream py-20">
    <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
      <div>
        <h2 class="font-serif text-4xl md:text-5xl text-heading-gray mb-8 uppercase tracking-wide">
          {p.homeContact.title}
        </h2>
        <p class="text-body-gray text-lg leading-relaxed">
          {p.homeContact.body}
        </p>
      </div>
      <ContactForm />
    </div>
  </section>

</Layout>
