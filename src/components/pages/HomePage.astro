---
import Layout from "../../layouts/Layout.astro";
import HeroImage from "../HeroImage.astro";
import ContactForm from "../ContactForm.astro";
import { getLang, routes, useTranslations } from "../../i18n/index";

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const p = t.pages.home;
const r = routes[lang];

// Background photos for the 4 category cards (Planeación, Banquete, Música, Duración)
const categoryImages = [
  "/images/img-1.jpg",
  "/images/img-3.jpg",
  "/images/gallery-2.jpg",
  "/images/img-vert-3.jpg",
];

// Portfolio teaser gallery — masonry mix of portrait + landscape photos
const portfolioImages = [
  "/images/gallery/g01.jpg",
  "/images/gallery/g02.jpg",
  "/images/gallery/g03.jpg",
  "/images/gallery/g04.jpg",
  "/images/gallery/g05.jpg",
  "/images/gallery/g09.jpg",
  "/images/gallery/g08.jpg",
  "/images/gallery/g11.jpg",
  "/images/gallery/g13.jpg",
  "/images/gallery/g17.jpg",
  "/images/gallery/g16.jpg",
  "/images/gallery/g22.jpg",
];

// Client avatars, in the same order as the testimonials
const testimonialAvatars = [
  "/images/avatar-3.jpg",
  "/images/yarene-sergio-150x150.jpg",
  "/images/martha-sergio-1-150x150.jpg",
];
---

<Layout title={p.meta.title} description={p.meta.description}>
  <HeroImage heroImage="/images/hero-beach.png" fixImage disableGreyscale>
    <div class="absolute inset-0 bg-black/40"></div>

    <!-- Centered circular badge logo (real asset from brand) -->
    <div class="absolute inset-0 z-10 flex items-center justify-center">
      <img
        src="/images/logo-badge.png"
        alt="Alice Cantón Weddings & Events"
        class="h-72 w-72 object-contain md:h-96 md:w-96"
      />
    </div>
  </HeroImage>

  <!-- ② INTRO: image left + value proposition text right -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-1 items-center gap-12 md:grid-cols-2">
        <!-- Image (left) -->
        <div>
          <img
            src="/images/boda-ciudad-1024x576.jpg"
            alt="Boda en Mérida Yucatán"
            class="h-auto w-full object-cover"
          />
        </div>
        <!-- Intro heading and text (right) -->
        <div class="text-center md:text-left">
          <h1
            class="text-heading-gray mb-8 font-serif text-4xl tracking-wide uppercase md:text-5xl"
          >
            {p.intro.title}
          </h1>
          <p class="text-body-gray text-lg leading-relaxed">
            {p.intro.body}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ③ CATEGORIES: 4-column grid of keyword cards -->
  <div class="grid w-full grid-cols-2 md:grid-cols-4">
    {
      p.categories.map((cat, i) => (
        <div
          class="group relative h-56 overflow-hidden bg-cover bg-center"
          style={`background-image: url('${categoryImages[i]}');`}
        >
          <div class="absolute inset-0 bg-black/40 transition-colors duration-300 group-hover:bg-black/25" />
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="px-4 text-center font-serif text-2xl tracking-widest text-white uppercase">
              {cat.label}
            </span>
          </div>
        </div>
      ))
    }
  </div>

  <!-- ④ SERVICES: Three service cards with descriptions -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h2
        class="text-heading-gray mb-16 text-center font-serif text-4xl tracking-wide uppercase md:text-5xl"
      >
        {p.services.title}
      </h2>
      <div class="grid grid-cols-1 gap-12 md:grid-cols-3">
        {
          p.services.items.map((service) => (
            <div class="text-center">
              <h3 class="text-heading-gray mb-6 font-serif text-2xl tracking-wide uppercase">
                {service.title}
              </h3>
              <p class="text-body-gray text-base leading-relaxed">
                {service.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ⑤ STORY: "Nuestra Historia" with text and bouquet image -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-1 items-start gap-12 md:grid-cols-2">
        <!-- Text column (left) -->
        <div>
          <h2
            class="text-heading-gray mb-4 text-center font-serif text-4xl tracking-wide uppercase md:text-5xl"
          >
            {p.history.title}
          </h2>
          <p
            class="text-heading-gray mb-8 text-center font-serif text-sm tracking-widest uppercase"
          >
            {p.history.subtitle}
          </p>
          <div
            class="text-accent-gold my-6 text-center text-3xl"
            aria-hidden="true"
          >
            ◆
          </div>
          <p class="text-body-gray mb-6 text-base leading-relaxed">
            {p.history.body1}
          </p>
          <p class="text-body-gray mb-8 text-base leading-relaxed">
            {p.history.body2}
          </p>
          <a
            href={r.contact}
            class="bg-button-dark inline-block px-8 py-3 font-serif text-sm tracking-widest text-white uppercase transition-opacity hover:opacity-90"
          >
            {p.history.cta}
          </a>
        </div>

        <!-- Image column (right) -->
        <div class="hidden md:block">
          <img
            src="/images/wedding-bouquet-pakbnhh.jpg"
            alt="Wedding bouquet"
            class="h-auto w-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ⑥ QUOTE BAND: standalone romantic pull-quote -->
  <section class="bg-teal-bg py-24 text-center">
    <div class="mx-auto max-w-4xl px-6">
      <blockquote
        class="mb-8 font-serif text-2xl leading-relaxed text-white italic md:text-4xl"
      >
        “{p.quote.text}”
      </blockquote>
      <p
        class="text-accent-gold font-serif text-sm tracking-[0.25em] uppercase"
      >
        {p.quote.attribution}
      </p>
    </div>
  </section>

  <!-- ⑦ PORTFOLIO GALLERY: masonry of wedding images -->
  <section class="bg-white">
    <div class="columns-2 gap-1 md:columns-4 [&>*]:mb-1">
      {
        portfolioImages.map((src) => (
          <div class="group break-inside-avoid overflow-hidden">
            <img
              src={src}
              alt="Wedding portfolio"
              loading="lazy"
              class="block w-full transition-transform duration-500 group-hover:scale-105"
            />
          </div>
        ))
      }
    </div>
  </section>

  <!-- ⑧ TESTIMONIALS QUOTE BAND -->
  <section class="bg-teal-bg py-16 text-center">
    <div class="mx-auto max-w-4xl px-6">
      <blockquote
        class="mb-6 font-serif text-3xl leading-relaxed text-white italic md:text-4xl"
      >
        {p.quoteBand.text}
      </blockquote>
      <p class="font-serif text-lg tracking-widest text-white/90 uppercase">
        {p.quoteBand.attribution}
      </p>
    </div>
  </section>

  <!-- ⑨ TESTIMONIALS: Review cards with client feedback -->
  <section
    class="relative bg-cover bg-fixed bg-center py-24"
    style="background-image: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), url('/images/parallax-2.jpg');"
  >
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        {
          p.testimonials.items.map((item, i) => (
            <div class="bg-white/95 p-8">
              <p class="text-body-gray mb-8 text-base leading-relaxed italic">
                "{item.quote}"
              </p>
              <div class="flex items-center gap-4">
                <div class="h-14 w-14 flex-shrink-0 overflow-hidden rounded-full">
                  <img
                    src={testimonialAvatars[i]}
                    alt={item.author}
                    class="h-full w-full object-cover"
                  />
                </div>
                <div>
                  <p class="text-heading-gray font-serif text-sm tracking-wide uppercase">
                    {item.author}
                  </p>
                  <p class="text-body-gray text-xs">{item.year}</p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ⑩ CTA BAND: Special day quote -->
  <section class="bg-teal-bg py-16 text-center">
    <div class="mx-auto max-w-4xl px-6">
      <h2
        class="font-serif text-3xl leading-relaxed tracking-wide text-white uppercase md:text-4xl"
      >
        {p.ctaBand.text}
      </h2>
    </div>
  </section>

  <!-- ⑪ CONTACT SECTION: "Platiquemos" with form -->
  <section class="bg-cream py-20">
    <div
      class="mx-auto grid max-w-6xl grid-cols-1 items-start gap-12 px-6 md:grid-cols-2"
    >
      <div>
        <h2
          class="text-heading-gray mb-8 font-serif text-4xl tracking-wide uppercase md:text-5xl"
        >
          {p.homeContact.title}
        </h2>
        <p class="text-body-gray text-lg leading-relaxed">
          {p.homeContact.body}
        </p>
      </div>
      <ContactForm />
    </div>
  </section>
</Layout>
