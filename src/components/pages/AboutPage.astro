---
import Layout from "../../layouts/Layout.astro";
import ContactForm from "../ContactForm.astro";
import { getLang, routes, useTranslations } from "../../i18n/index";
import HeroImage from "../HeroImage.astro";

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const p = t.pages.about;
const r = routes[lang];

const img10 = "/images/img-10.jpg";
const img13 = "/images/img-13.jpg";
---

<Layout title={p.meta.title} description={p.meta.description}>
  <HeroImage
    heroImage="/images/parallax-2.jpg"
    title={p.hero.title}
    className="bg-position-[100%_top]"
  />

  <!-- ② QUERIDOS NOVIOS -->
  <section class="bg-white py-20 text-center">
    <div class="mx-auto max-w-3xl px-6">
      <h2
        class="text-charcoal mb-8 font-serif text-3xl md:text-4xl"
        style="font-variant: small-caps;"
      >
        {p.intro.title}
      </h2>
      <div class="space-y-5">
        {
          p.intro.body.map((para) => (
            <p class="text-sm leading-relaxed text-gray-600" set:html={para} />
          ))
        }
      </div>
    </div>
  </section>

  <!-- ③ ALICE CANTON FOUNDER -->
  <section class="relative overflow-hidden py-20 md:py-28">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style={`background-image: url('${img13}');`}
    >
    </div>
    <div class="bg-cream/85 absolute inset-0"></div>
    <div class="relative z-10 mx-auto max-w-6xl px-6">
      <div
        class="grid grid-cols-1 items-center gap-12 md:grid-cols-2 md:gap-16"
      >
        <!-- Founder bio card -->
        <div
          class="border-gold/40 border bg-white px-8 py-12 text-center shadow-lg md:px-10"
        >
          <h2
            class="text-charcoal font-serif text-2xl leading-tight"
            style="font-variant: small-caps;"
          >
            Alice Cantón
          </h2>
          <p
            class="text-charcoal/70 mt-1 font-serif text-base"
            style="font-variant: small-caps;"
          >
            Wedding Planner en Mérida Yucatán
          </p>
          <p
            class="text-charcoal/70 mt-1 font-serif text-lg"
            style="font-variant: small-caps;"
          >
            {p.founder.role}
          </p>
          <div class="text-gold my-4 text-2xl" aria-hidden="true">♛</div>
          <p class="mb-4 text-sm leading-relaxed text-gray-500">
            {p.founder.bio}
          </p>
          <p class="mb-4 text-sm leading-relaxed text-gray-500">
            {p.founder.quote}
          </p>
          <p class="text-sm leading-relaxed text-gray-500">{p.founder.note}</p>
        </div>

        <!-- Alice's photo, matted with an offset gold frame -->
        <div class="flex justify-center md:justify-start">
          <div class="group relative w-full max-w-lg">
            <span
              class="border-gold/60 absolute -top-4 -left-4 hidden h-full w-full border sm:block"
              aria-hidden="true"></span>
            <img
              src="/images/alice-canton-helping-bride.png"
              alt="Alice Cantón ayudando a una novia"
              loading="lazy"
              class="relative aspect-[4/3] w-full object-cover object-center shadow-xl transition-transform duration-700 group-hover:scale-[1.02]"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ④ MISIÓN: stationery image left, forest-green text right -->
  <section class="grid grid-cols-1 md:grid-cols-2">
    <div
      class="min-h-[420px] bg-cover bg-center"
      style={`background-image: url('${img10}');`}
    >
    </div>
    <div class="bg-forest flex flex-col justify-center px-10 py-16 md:px-14">
      <h2
        class="mb-3 font-serif text-3xl text-white md:text-4xl"
        style="font-variant: small-caps;"
      >
        {p.values.items[1].title}
      </h2>
      <div class="bg-gold mb-6 h-0.5 w-8"></div>
      <p
        class="text-sm leading-relaxed text-white/85"
        set:html={p.values.items[1].text}
      />
    </div>
  </section>

  <!-- ⑤ VISIÓN: forest-green text left, image right -->
  <section class="grid grid-cols-1 md:grid-cols-2">
    <div class="bg-forest flex flex-col justify-center px-10 py-16 md:px-14">
      <h2
        class="mb-3 font-serif text-3xl text-white md:text-4xl"
        style="font-variant: small-caps;"
      >
        {p.values.items[0].title}
      </h2>
      <div class="bg-gold mb-6 h-0.5 w-8"></div>
      <p
        class="text-sm leading-relaxed text-white/85"
        set:html={p.values.items[0].text}
      />
    </div>
    <div
      class="min-h-[420px] bg-cover bg-center"
      style={`background-image: url('${img13}');`}
    >
    </div>
  </section>

  <!-- ⑥ OBJETIVOS: forest-green centered, bullet sentences -->
  <section class="bg-forest py-16 text-center">
    <div class="mx-auto max-w-2xl px-6">
      <h2
        class="mb-3 font-serif text-3xl text-white md:text-4xl"
        style="font-variant: small-caps;"
      >
        {p.values.items[2].title}
      </h2>
      <div class="bg-gold mx-auto mb-8 h-0.5 w-8"></div>
      <div class="space-y-3">
        {
          p.values.items[2].text
            .split("\n")
            .map((line) => (
              <p class="text-sm leading-relaxed text-white/85">{line}</p>
            ))
        }
      </div>
    </div>
  </section>

  <!-- ⑦ ORGANIZACIÓN BODA: full-width title, then image left + steps right -->
  <section class="bg-white">
    <div class="px-6 py-12 text-center">
      <h2
        class="text-charcoal font-serif text-4xl leading-tight md:text-5xl"
        style="font-variant: small-caps;"
      >
        {p.process.title.split("\n")[0]}
      </h2>
      <p
        class="text-charcoal/60 mt-1 font-serif text-2xl md:text-3xl"
        style="font-variant: small-caps;"
      >
        {p.process.title.split("\n")[1]}
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2">
      <div
        class="hidden min-h-[420px] bg-cover bg-center md:block"
        style={`background-image: url('${img10}');`}
      >
      </div>
      <div class="flex flex-col justify-center bg-white px-10 py-12 md:px-16">
        <div class="mx-auto flex w-full max-w-xs flex-col gap-0">
          {
            p.process.steps.map((step, i) => (
              <div class="flex w-full items-start gap-4">
                <div class="flex flex-shrink-0 flex-col items-center">
                  <div class="bg-forest flex h-9 min-w-[2.5rem] items-center justify-center rounded-md px-3 font-serif text-sm font-semibold text-white">
                    {step.num}
                  </div>
                  {i < p.process.steps.length - 1 && (
                    <div class="bg-forest/30 my-1 h-8 w-px" />
                  )}
                </div>
                <p class="text-charcoal pt-2 font-serif text-sm">
                  {step.title}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ⑧ PLATIQUEMOS: full-width bg, centered white card with form -->
  <section class="relative py-20">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style="background-image: url('/images/parallax-2.jpg');"
    >
    </div>
    <div class="absolute inset-0 bg-black/30"></div>
    <div class="relative z-10 mx-auto max-w-xl px-6">
      <div class="bg-white px-8 py-10 md:px-12">
        <h2
          class="text-charcoal mb-6 text-center font-serif text-3xl"
          style="font-variant: small-caps;"
        >
          {t.cta.title}
        </h2>
        <ContactForm
          singleColumn={true}
          showDate={false}
          bare={true}
          submitLabel={lang === "es" ? "Enviar" : "Send"}
        />
      </div>
    </div>
  </section>

  <!-- ⑨ GOLD CONTACT BAR -->
  <section class="bg-gold text-white">
    <div
      class="mx-auto grid max-w-5xl grid-cols-1 divide-y divide-white/30 px-6 py-12 text-center md:grid-cols-3 md:divide-x md:divide-y-0"
    >
      {
        p.contactBar.items.map((item, i) => {
          const href =
            i === 0
              ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${item.value}, Yucatán, México`)}`
              : i === 1
                ? `tel:${item.value.replace(/[^\d+]/g, "")}`
                : `mailto:${item.value}`;
          const external = i === 0;
          return (
            <a
              href={href}
              target={external ? "_blank" : undefined}
              rel={external ? "noopener noreferrer" : undefined}
              class="group block px-6 py-4 transition-colors hover:bg-white/10 md:py-2"
            >
              <h3
                class="mb-1 font-serif text-lg"
                style="font-variant: small-caps;"
              >
                {item.label}
              </h3>
              <p class="text-sm break-words text-white/90 underline-offset-4 group-hover:underline">
                {item.value}
              </p>
            </a>
          );
        })
      }
    </div>
  </section>
</Layout>
