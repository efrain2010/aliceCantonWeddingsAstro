---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../ContactForm.astro';
import { getLang, routes, useTranslations } from '../../i18n/index';

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const p = t.pages.about;
const r = routes[lang];

const img10 = '/images/img-10.jpg';
const img13 = '/images/img-13.jpg';
---

<Layout title={p.meta.title} description={p.meta.description}>

  <!-- ① HERO: full-height B&W photo + Great Vibes script title -->
  <section class="relative min-h-screen overflow-hidden">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style="background-image: url('/images/parallax-2.jpg'); filter: grayscale(100%);"
    />
    <div class="absolute inset-0 bg-black/20" />
    <div class="relative z-10 flex items-center justify-center min-h-screen px-6 text-center">
      <h1
        class="text-white leading-none"
        style="font-family: 'Great Vibes', cursive; font-size: clamp(5rem, 12vw, 10rem); font-weight: 400;"
      >
        {p.hero.title}
      </h1>
    </div>
  </section>

  <!-- ② QUERIDOS NOVIOS -->
  <section class="py-20 bg-white text-center">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="font-serif text-3xl md:text-4xl text-charcoal mb-8" style="font-variant: small-caps;">{p.intro.title}</h2>
      <div class="space-y-5">
        {p.intro.body.map(para => (
          <p class="text-gray-600 leading-relaxed text-sm" set:html={para} />
        ))}
      </div>
    </div>
  </section>

  <!-- ③ ALICE CANTON FOUNDER -->
  <section class="relative py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${img13}');`} />
    <div class="absolute inset-0 bg-cream/85" />
    <div class="relative z-10 max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-center">

        <!-- Founder bio card -->
        <div class="bg-white border border-gold/40 px-8 md:px-10 py-12 text-center shadow-lg">
          <h2 class="font-serif text-2xl text-charcoal leading-tight" style="font-variant: small-caps;">Alice Cantón</h2>
          <p class="font-serif text-base text-charcoal/70 mt-1" style="font-variant: small-caps;">Wedding Planner en Mérida Yucatán</p>
          <p class="font-serif text-lg text-charcoal/70 mt-1" style="font-variant: small-caps;">{p.founder.role}</p>
          <div class="text-gold text-2xl my-4" aria-hidden="true">♛</div>
          <p class="text-gray-500 text-sm leading-relaxed mb-4">{p.founder.bio}</p>
          <p class="text-gray-500 text-sm leading-relaxed mb-4">{p.founder.quote}</p>
          <p class="text-gray-500 text-sm leading-relaxed">{p.founder.note}</p>
        </div>

        <!-- Alice's photo, matted with an offset gold frame -->
        <div class="flex justify-center md:justify-start">
          <div class="relative group max-w-lg w-full">
            <span class="hidden sm:block absolute -top-4 -left-4 w-full h-full border border-gold/60" aria-hidden="true"></span>
            <img
              src="/images/alice-canton-helping-bride.png"
              alt="Alice Cantón ayudando a una novia"
              loading="lazy"
              class="relative w-full aspect-[4/3] object-cover object-center shadow-xl transition-transform duration-700 group-hover:scale-[1.02]"
            />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ④ MISIÓN: stationery image left, forest-green text right -->
  <section class="grid grid-cols-1 md:grid-cols-2">
    <div
      class="min-h-[420px] bg-cover bg-center"
      style={`background-image: url('${img10}');`}
    />
    <div class="bg-forest flex flex-col justify-center px-10 md:px-14 py-16">
      <h2 class="font-serif text-3xl md:text-4xl text-white mb-3" style="font-variant: small-caps;">{p.values.items[1].title}</h2>
      <div class="w-8 h-0.5 bg-gold mb-6" />
      <p class="text-white/85 text-sm leading-relaxed" set:html={p.values.items[1].text} />
    </div>
  </section>

  <!-- ⑤ VISIÓN: forest-green text left, image right -->
  <section class="grid grid-cols-1 md:grid-cols-2">
    <div class="bg-forest flex flex-col justify-center px-10 md:px-14 py-16">
      <h2 class="font-serif text-3xl md:text-4xl text-white mb-3" style="font-variant: small-caps;">{p.values.items[0].title}</h2>
      <div class="w-8 h-0.5 bg-gold mb-6" />
      <p class="text-white/85 text-sm leading-relaxed" set:html={p.values.items[0].text} />
    </div>
    <div
      class="min-h-[420px] bg-cover bg-center"
      style={`background-image: url('${img13}');`}
    />
  </section>

  <!-- ⑥ OBJETIVOS: forest-green centered, bullet sentences -->
  <section class="bg-forest py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-3xl md:text-4xl text-white mb-3" style="font-variant: small-caps;">{p.values.items[2].title}</h2>
      <div class="w-8 h-0.5 bg-gold mx-auto mb-8" />
      <div class="space-y-3">
        {p.values.items[2].text.split('\n').map(line => (
          <p class="text-white/85 text-sm leading-relaxed">{line}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑦ ORGANIZACIÓN BODA: full-width title, then image left + steps right -->
  <section class="bg-white">
    <div class="text-center py-12 px-6">
      <h2 class="font-serif text-4xl md:text-5xl text-charcoal leading-tight" style="font-variant: small-caps;">{p.process.title.split('\n')[0]}</h2>
      <p class="font-serif text-2xl md:text-3xl text-charcoal/60 mt-1" style="font-variant: small-caps;">{p.process.title.split('\n')[1]}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2">
      <div
        class="min-h-[420px] bg-cover bg-center hidden md:block"
        style={`background-image: url('${img10}');`}
      />
      <div class="flex flex-col justify-center px-10 md:px-16 py-12 bg-white">
        <div class="flex flex-col gap-0 max-w-xs mx-auto w-full">
          {p.process.steps.map((step, i) => (
            <div class="flex items-start gap-4 w-full">
              <div class="flex flex-col items-center flex-shrink-0">
                <div class="min-w-[2.5rem] px-3 h-9 rounded-md bg-forest flex items-center justify-center text-white font-serif text-sm font-semibold">
                  {step.num}
                </div>
                {i < p.process.steps.length - 1 && (
                  <div class="w-px h-8 bg-forest/30 my-1" />
                )}
              </div>
              <p class="font-serif text-charcoal text-sm pt-2">{step.title}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ⑧ PLATIQUEMOS: full-width bg, centered white card with form -->
  <section class="relative py-20">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style="background-image: url('/images/parallax-2.jpg');"
    />
    <div class="absolute inset-0 bg-black/30" />
    <div class="relative z-10 max-w-xl mx-auto px-6">
      <div class="bg-white px-8 py-10 md:px-12">
        <h2 class="font-serif text-3xl text-charcoal mb-6 text-center" style="font-variant: small-caps;">{t.cta.title}</h2>
        <ContactForm singleColumn={true} showDate={false} bare={true} submitLabel={lang === 'es' ? 'Enviar' : 'Send'} />
      </div>
    </div>
  </section>

  <!-- ⑨ GOLD CONTACT BAR -->
  <section class="bg-gold text-white">
    <div class="max-w-5xl mx-auto px-6 py-12 grid grid-cols-1 md:grid-cols-3 text-center divide-y md:divide-y-0 md:divide-x divide-white/30">
      {p.contactBar.items.map((item, i) => {
        const href =
          i === 0
            ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${item.value}, Yucatán, México`)}`
            : i === 1
              ? `tel:${item.value.replace(/[^\d+]/g, '')}`
              : `mailto:${item.value}`;
        const external = i === 0;
        return (
          <a
            href={href}
            target={external ? '_blank' : undefined}
            rel={external ? 'noopener noreferrer' : undefined}
            class="group block py-4 md:py-2 px-6 hover:bg-white/10 transition-colors"
          >
            <h3 class="font-serif text-lg mb-1" style="font-variant: small-caps;">{item.label}</h3>
            <p class="text-white/90 text-sm group-hover:underline underline-offset-4 break-words">{item.value}</p>
          </a>
        );
      })}
    </div>
  </section>

</Layout>
