---
import { getLang } from "../i18n/index";
import LoadingSpinner from "./LoadingSpinner.astro";

interface Props {
  group?: string;
}

const { group = "default" } = Astro.props;
const lang = getLang(Astro.url.pathname);

const labels =
  lang === "en"
    ? { close: "Close", prev: "Previous image", next: "Next image" }
    : { close: "Cerrar", prev: "Imagen anterior", next: "Imagen siguiente" };
---

<div
  aria-label={labels.close}
  class="gallery-lightbox fixed inset-0 z-100 hidden items-center justify-center overflow-hidden bg-black/85 opacity-0 transition-opacity duration-300 ease-out"
  data-group={group}
  role="dialog"
>
  <div class="gallery-lightbox-backdrop absolute inset-0"></div>

  <button
    aria-label={labels.close}
    class="gallery-lightbox-close absolute top-3 right-3 z-10 flex h-10 w-10 cursor-pointer items-center justify-center rounded-full text-white/90 transition hover:bg-white/10 md:top-6 md:right-6"
    type="button"
  >
    <svg fill="none" height="20" viewBox="0 0 24 24" width="20">
      <path
        d="M6 6l12 12M18 6L6 18"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-width="2"
      />
    </svg>
  </button>

  <button
    aria-label={labels.prev}
    class="gallery-lightbox-prev absolute top-1/2 left-1 z-10 flex h-10 w-10 -translate-y-1/2 cursor-pointer items-center justify-center rounded-full text-white/90 transition hover:bg-white/10 md:left-4"
    type="button"
  >
    <svg fill="none" height="20" viewBox="0 0 24 24" width="20">
      <path
        d="M15 6l-6 6 6 6"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
      />
    </svg>
  </button>

  <button
    aria-label={labels.next}
    class="gallery-lightbox-next absolute top-1/2 right-1 z-10 flex h-10 w-10 -translate-y-1/2 cursor-pointer items-center justify-center rounded-full text-white/90 transition hover:bg-white/10 md:right-4"
    type="button"
  >
    <svg fill="none" height="20" viewBox="0 0 24 24" width="20">
      <path
        d="M9 6l6 6-6 6"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
      />
    </svg>
  </button>

  <div
    class="gallery-lightbox-stage relative mx-auto flex h-full w-full min-h-0 min-w-0 scale-95 items-center justify-center overflow-hidden transition-transform duration-300 ease-out md:h-[85vh] md:max-w-5xl md:rounded-lg md:shadow-2xl"
  >
    <img
      alt=""
      class="gallery-lightbox-img h-full max-h-full w-full max-w-full min-h-0 min-w-0 touch-none object-contain opacity-0 transition-opacity duration-200 select-none"
      draggable="false"
    />
    <div
      aria-hidden="true"
      class="gallery-lightbox-spinner absolute inset-0 hidden items-center justify-center"
    >
      <LoadingSpinner />
    </div>
  </div>
</div>

<script>
  const MIN_SCALE = 1;
  const MAX_SCALE = 3;
  const DOUBLE_TAP_SCALE = 2;
  const DOUBLE_TAP_WINDOW_MS = 300;

  function initLightbox(root: HTMLElement) {
    const group = root.dataset.group ?? "default";
    const triggers = Array.from(
      document.querySelectorAll<HTMLElement>(
        `.gallery-trigger[data-group="${group}"]`,
      ),
    );
    if (triggers.length === 0) return;

    const items = triggers.map((trigger) => ({
      full: trigger.dataset.full ?? "",
      alt: trigger.dataset.alt ?? "",
    }));

    const img = root.querySelector<HTMLImageElement>(".gallery-lightbox-img");
    const stage = root.querySelector<HTMLElement>(".gallery-lightbox-stage");
    const backdrop = root.querySelector<HTMLElement>(
      ".gallery-lightbox-backdrop",
    );
    const closeBtn = root.querySelector<HTMLElement>(".gallery-lightbox-close");
    const prevBtn = root.querySelector<HTMLElement>(".gallery-lightbox-prev");
    const nextBtn = root.querySelector<HTMLElement>(".gallery-lightbox-next");
    const spinner = root.querySelector<HTMLElement>(
      ".gallery-lightbox-spinner",
    );
    if (
      !img ||
      !stage ||
      !backdrop ||
      !closeBtn ||
      !prevBtn ||
      !nextBtn ||
      !spinner
    )
      return;

    let currentIndex = 0;
    let scale = 1;
    let panX = 0;
    let panY = 0;

    const applyTransform = () => {
      img.style.transform = `translate(${panX}px, ${panY}px) scale(${scale})`;
    };

    const resetZoom = () => {
      scale = 1;
      panX = 0;
      panY = 0;
      applyTransform();
    };

    const setLoading = (loading: boolean) => {
      spinner.classList.toggle("hidden", !loading);
      spinner.classList.toggle("flex", loading);
      img.classList.toggle("opacity-0", loading);
    };

    // Wait for the image to be fully decoded (not just downloaded) before
    // revealing it, otherwise large photos can flash a partially painted
    // frame while the browser finishes decoding off the main thread.
    let loadToken = 0;
    const handleLoad = (token: number) => {
      if (typeof img.decode === "function") {
        img.decode().then(
          () => token === loadToken && setLoading(false),
          () => token === loadToken && setLoading(false),
        );
      } else if (token === loadToken) {
        setLoading(false);
      }
    };

    const show = (index: number) => {
      currentIndex = (index + items.length) % items.length;
      const item = items[currentIndex];
      setLoading(true);
      loadToken += 1;
      const token = loadToken;
      img.onload = () => handleLoad(token);
      img.onerror = () => token === loadToken && setLoading(false);
      img.src = item.full;
      img.alt = item.alt;
      resetZoom();
    };

    const isOpen = () => !root.classList.contains("hidden");
    let closeTimeoutId = 0;

    const open = (index: number) => {
      window.clearTimeout(closeTimeoutId);
      show(index);
      root.classList.remove("hidden");
      root.classList.add("flex");
      document.documentElement.classList.add("overflow-hidden");
      // Force layout with the starting (faded/scaled-down) styles applied
      // before flipping to the open state, so the transition actually runs.
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          root.classList.remove("opacity-0");
          stage.classList.remove("scale-95");
        });
      });
    };

    const close = () => {
      window.clearTimeout(closeTimeoutId);
      root.classList.add("opacity-0");
      stage.classList.add("scale-95");
      document.documentElement.classList.remove("overflow-hidden");
      closeTimeoutId = window.setTimeout(() => {
        root.classList.remove("flex");
        root.classList.add("hidden");
      }, 300);
    };

    const next = () => show(currentIndex + 1);
    const prev = () => show(currentIndex - 1);

    triggers.forEach((trigger, index) => {
      trigger.addEventListener("click", () => open(index));
    });

    closeBtn.addEventListener("click", close);
    backdrop.addEventListener("click", close);
    nextBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      next();
    });
    prevBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      prev();
    });

    document.addEventListener("keydown", (e) => {
      if (!isOpen()) return;
      if (e.key === "Escape") close();
      if (e.key === "ArrowRight") next();
      if (e.key === "ArrowLeft") prev();
    });

    // Touch gestures: pinch-to-zoom (max 3x), double-tap zoom (2x),
    // drag-to-pan when zoomed, and swipe left/right to navigate when not
    // zoomed in. Each gesture gets its own start/update/end functions so
    // the touchstart/move/end listeners stay thin dispatchers.
    const SWIPE_THRESHOLD_PX = 40;
    const SWIPE_MAX_DURATION_MS = 600;
    const SWIPE_INTENT_PX = 10;
    const DOUBLE_TAP_MAX_DISTANCE_PX = 30;

    let pinchStartDistance = 0;
    let pinchStartScale = 1;
    let lastTapTime = 0;
    let lastTapX = 0;
    let lastTapY = 0;
    let isDragging = false;
    let dragStartX = 0;
    let dragStartY = 0;
    let dragStartPanX = 0;
    let dragStartPanY = 0;
    let swipeStartX = 0;
    let swipeStartY = 0;
    let swipeStartTime = 0;

    const touchDistance = (touches: TouchList) =>
      Math.hypot(
        touches[1].clientX - touches[0].clientX,
        touches[1].clientY - touches[0].clientY,
      );

    const isZoomed = () => scale > MIN_SCALE;

    // -- Pinch-to-zoom --------------------------------------------------
    const startPinch = (touches: TouchList) => {
      pinchStartDistance = touchDistance(touches);
      pinchStartScale = scale;
      isDragging = false;
    };

    const updatePinch = (touches: TouchList) => {
      const ratio = touchDistance(touches) / pinchStartDistance;
      scale = Math.min(MAX_SCALE, Math.max(MIN_SCALE, pinchStartScale * ratio));
      applyTransform();
    };

    // -- Double-tap zoom --------------------------------------------------
    const handleDoubleTap = (touch: Touch) => {
      const now = Date.now();
      const distanceFromLastTap = Math.hypot(
        touch.clientX - lastTapX,
        touch.clientY - lastTapY,
      );
      const isDoubleTap =
        now - lastTapTime < DOUBLE_TAP_WINDOW_MS &&
        distanceFromLastTap < DOUBLE_TAP_MAX_DISTANCE_PX;

      lastTapTime = isDoubleTap ? 0 : now;
      lastTapX = touch.clientX;
      lastTapY = touch.clientY;
      if (!isDoubleTap) return;

      scale = isZoomed() ? MIN_SCALE : DOUBLE_TAP_SCALE;
      panX = 0;
      panY = 0;
      applyTransform();
    };

    // -- Drag-to-pan (only while zoomed in) ------------------------------
    const startPan = (touch: Touch) => {
      if (!isZoomed()) return;
      isDragging = true;
      dragStartX = touch.clientX;
      dragStartY = touch.clientY;
      dragStartPanX = panX;
      dragStartPanY = panY;
    };

    const updatePan = (touch: Touch) => {
      panX = dragStartPanX + (touch.clientX - dragStartX);
      panY = dragStartPanY + (touch.clientY - dragStartY);
      applyTransform();
    };

    // -- Swipe-to-navigate (only while not zoomed in) --------------------
    const recordSwipeStart = (touch: Touch) => {
      swipeStartX = touch.clientX;
      swipeStartY = touch.clientY;
      swipeStartTime = Date.now();
    };

    const isHorizontalDrag = (touch: Touch, minDistance: number) => {
      const deltaX = touch.clientX - swipeStartX;
      const deltaY = touch.clientY - swipeStartY;
      return (
        Math.abs(deltaX) > minDistance &&
        Math.abs(deltaX) > Math.abs(deltaY) * 1.5
      );
    };

    const finishSwipe = (touch: Touch) => {
      const elapsed = Date.now() - swipeStartTime;
      if (elapsed >= SWIPE_MAX_DURATION_MS) return;
      if (!isHorizontalDrag(touch, SWIPE_THRESHOLD_PX)) return;

      const deltaX = touch.clientX - swipeStartX;
      if (deltaX < 0) next();
      else prev();
    };

    // -- Event listeners --------------------------------------------------
    img.addEventListener("touchstart", (e) => {
      if (e.touches.length === 2) {
        startPinch(e.touches);
        return;
      }

      if (e.touches.length !== 1) return;

      const touch = e.touches[0];
      recordSwipeStart(touch);
      handleDoubleTap(touch);
      startPan(touch);
    });

    img.addEventListener(
      "touchmove",
      (e) => {
        if (e.touches.length === 2) {
          e.preventDefault();
          updatePinch(e.touches);
          return;
        }

        if (e.touches.length !== 1) return;
        const touch = e.touches[0];

        if (isDragging && isZoomed()) {
          e.preventDefault();
          updatePan(touch);
          return;
        }

        // Not zoomed: a horizontal drag is a swipe-in-progress. Suppress
        // the browser's own gesture handling (e.g. edge-swipe back nav).
        if (!isZoomed() && isHorizontalDrag(touch, SWIPE_INTENT_PX)) {
          e.preventDefault();
        }
      },
      { passive: false },
    );

    img.addEventListener("touchend", (e) => {
      if (e.touches.length !== 0) return;
      isDragging = false;
      if (isZoomed()) return;

      panX = 0;
      panY = 0;
      applyTransform();

      const touch = e.changedTouches[0];
      if (touch) finishSwipe(touch);
    });

    // Desktop convenience: double-click to zoom
    img.addEventListener("dblclick", () => {
      scale = scale > MIN_SCALE ? MIN_SCALE : DOUBLE_TAP_SCALE;
      panX = 0;
      panY = 0;
      applyTransform();
    });
  }

  document
    .querySelectorAll<HTMLElement>(".gallery-lightbox")
    .forEach(initLightbox);
</script>
