---
interface Props {
  title: string;
  description: string;
  imageSrc?: string;
  reverse?: boolean;
  note?: string;
}
const { title, description, imageSrc, reverse = false, note } = Astro.props;
---

<div
  class={`flex flex-col ${reverse ? "md:flex-row-reverse" : "md:flex-row"} mb-0`}
>
  <!-- Image side -->
  <div class="h-72 overflow-hidden md:h-[420px] md:w-1/2">
    {
      imageSrc ? (
        <img
          alt={title}
          class="h-full w-full object-cover"
          loading="lazy"
          src={imageSrc}
        />
      ) : (
        <div
          class="flex h-full w-full items-center justify-center"
          style="background: linear-gradient(135deg, #E8D5C4 0%, #C9A96E55 100%);"
        >
          <span class="text-charcoal/40 font-serif text-2xl">{title}</span>
        </div>
      )
    }
  </div>

  <!-- Text side -->
  <div
    class="bg-cream flex flex-col justify-center px-10 py-12 md:w-1/2 md:py-16"
  >
    <h3 class="text-charcoal mb-4 font-serif text-2xl md:text-3xl">{title}</h3>
    <p class="mb-4 leading-relaxed text-gray-600">{description}</p>
    {
      note && (
        <p class="text-gold border-gold border-l-2 pl-4 text-sm italic">
          {note}
        </p>
      )
    }
  </div>
</div>
