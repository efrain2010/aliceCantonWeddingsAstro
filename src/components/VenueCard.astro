---
interface Props {
  title: string;
  description: string;
  imageSrc?: string;
  reverse?: boolean;
  note?: string;
}
const { title, description, imageSrc, reverse = false, note } = Astro.props;
---

<div
  class={`flex flex-col ${reverse ? "md:flex-row-reverse" : "md:flex-row"} mb-0`}
>
  <!-- Image side -->
  <div class="md:w-1/2 h-72 md:h-[420px] overflow-hidden">
    {
      imageSrc ? (
        <img
          src={imageSrc}
          alt={title}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      ) : (
        <div
          class="w-full h-full flex items-center justify-center"
          style="background: linear-gradient(135deg, #E8D5C4 0%, #C9A96E55 100%);"
        >
          <span class="font-serif text-2xl text-charcoal/40">{title}</span>
        </div>
      )
    }
  </div>

  <!-- Text side -->
  <div
    class="md:w-1/2 bg-cream px-10 py-12 md:py-16 flex flex-col justify-center"
  >
    <h3 class="font-serif text-2xl md:text-3xl text-charcoal mb-4">{title}</h3>
    <p class="text-gray-600 leading-relaxed mb-4">{description}</p>
    {
      note && (
        <p class="text-gold text-sm italic border-l-2 border-gold pl-4">
          {note}
        </p>
      )
    }
  </div>
</div>
