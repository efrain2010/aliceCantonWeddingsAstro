---
interface Props {
  title: string;
  description: string;
  icon?: string;
  href?: string;
}
const { title, description, icon = "✦", href } = Astro.props;
---

<div
  class="border-gold flex flex-col border-t-2 bg-white p-8 shadow-sm transition-shadow hover:shadow-md"
>
  <div class="text-gold mb-4 text-2xl">{icon}</div>
  <h3 class="text-charcoal mb-3 font-serif text-xl">{title}</h3>
  <p class="flex-1 text-sm leading-relaxed text-gray-600">{description}</p>
  {
    href && (
      <a
        href={href}
        class="text-gold hover:text-charcoal border-gold mt-6 self-start border-b pb-0.5 text-xs tracking-widest uppercase transition-colors"
      >
        Saber más
      </a>
    )
  }
</div>
