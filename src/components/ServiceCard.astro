---
interface Props {
  title: string;
  description: string;
  icon?: string;
  href?: string;
}
const { title, description, icon = "✦", href } = Astro.props;
---

<div
  class="bg-white p-8 shadow-sm hover:shadow-md transition-shadow border-t-2 border-gold flex flex-col"
>
  <div class="text-gold text-2xl mb-4">{icon}</div>
  <h3 class="font-serif text-xl mb-3 text-charcoal">{title}</h3>
  <p class="text-gray-600 text-sm leading-relaxed flex-1">{description}</p>
  {
    href && (
      <a
        href={href}
        class="mt-6 text-xs uppercase tracking-widest text-gold hover:text-charcoal transition-colors border-b border-gold pb-0.5 self-start"
      >
        Saber más
      </a>
    )
  }
</div>
