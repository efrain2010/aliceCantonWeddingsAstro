---
import { translations, routes, getLang, type Lang } from "../i18n/index";
import { CONTACT, phoneHref, emailHref } from "../config/site";

const lang: Lang = getLang(Astro.url.pathname);
const t = translations[lang];
const contactUrl = routes[lang].contact;
---

<section class="bg-gold py-16 text-center">
  <div class="mx-auto max-w-3xl px-6">
    <h2 class="mb-4 font-serif text-4xl text-white">{t.cta.title}</h2>
    <p class="mb-10 text-lg leading-relaxed text-white/90">
      {t.cta.subtitle}
    </p>
    <div
      class="flex flex-col flex-wrap items-center justify-center gap-4 sm:flex-row"
    >
      <a href={phoneHref} class="font-medium text-white hover:underline">
        {CONTACT.phone}
      </a>
      <span class="hidden text-white/50 sm:block">|</span>
      <a href={emailHref} class="font-medium text-white hover:underline">
        {CONTACT.email}
      </a>
      <span class="hidden text-white/50 sm:block">|</span>
      <a
        href={contactUrl}
        class="hover:text-gold border-2 border-white px-8 py-2.5 text-xs font-medium tracking-widest text-white uppercase transition-all duration-300 hover:bg-white"
      >
        {t.cta.button}
      </a>
    </div>
  </div>
</section>
