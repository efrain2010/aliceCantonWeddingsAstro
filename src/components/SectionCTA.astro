---
import { translations, routes, getLang, type Lang } from '../i18n/index';

const lang: Lang = getLang(Astro.url.pathname);
const t = translations[lang];
const contactUrl = routes[lang].contact;
---

<section class="bg-gold py-16 text-center">
  <div class="max-w-3xl mx-auto px-6">
    <h2 class="font-serif text-4xl text-white mb-4">{t.cta.title}</h2>
    <p class="text-white/90 text-lg mb-10 leading-relaxed">
      {t.cta.subtitle}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center flex-wrap">
      <a href="tel:9992928921" class="text-white font-medium hover:underline">
        999 292 8921
      </a>
      <span class="text-white/50 hidden sm:block">|</span>
      <a href="mailto:alicecantonweddings@gmail.com" class="text-white font-medium hover:underline">
        alicecantonweddings@gmail.com
      </a>
      <span class="text-white/50 hidden sm:block">|</span>
      <a
        href={contactUrl}
        class="border-2 border-white text-white px-8 py-2.5 hover:bg-white hover:text-gold transition-all duration-300 uppercase tracking-widest text-xs font-medium"
      >
        {t.cta.button}
      </a>
    </div>
  </div>
</section>
