---
interface Props {
  quote: string;
  author: string;
  year: string;
}
const { quote, author, year } = Astro.props;
---

<div class="relative flex flex-col bg-white p-8 shadow-sm">
  <div
    class="text-gold/25 absolute top-3 left-6 font-serif text-6xl leading-none select-none"
  >
    "
  </div>
  <p class="mt-8 mb-6 flex-1 text-sm leading-relaxed text-gray-600 italic">
    {quote}
  </p>
  <div class="border-rose border-t pt-4">
    <p class="text-charcoal text-sm font-medium">{author}</p>
    <p class="mt-0.5 text-xs text-gray-400">{year}</p>
  </div>
</div>
