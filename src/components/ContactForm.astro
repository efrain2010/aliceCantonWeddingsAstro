---
import { translations, getLang, type Lang } from "../i18n/index";
import { formEndpoint } from "../config/site";

interface Props {
  singleColumn?: boolean;
  showDate?: boolean;
  bare?: boolean;
  submitLabel?: string;
}
const {
  singleColumn = false,
  showDate = true,
  bare = false,
  submitLabel,
} = Astro.props;

const lang: Lang = getLang(Astro.url.pathname);
const f = translations[lang].form;
---

<form
  class={bare ? "w-full" : "bg-white p-8 md:p-10 shadow-sm max-w-2xl mx-auto"}
  method="POST"
  action={formEndpoint}
>
  <div
    class={`grid gap-6 mb-6 ${singleColumn ? "grid-cols-1" : "grid-cols-1 md:grid-cols-2"}`}
  >
    <div>
      <label
        for="nombre"
        class="text-charcoal mb-2 block text-xs font-medium tracking-widest uppercase"
        >{f.nameLabel}</label
      >
      <input
        type="text"
        id="nombre"
        name="nombre"
        required
        autocomplete="name"
        class="focus:border-gold text-charcoal w-full border-b-2 border-gray-200 bg-transparent py-2 placeholder-gray-300 transition-colors outline-none"
        placeholder={f.namePlaceholder}
      />
    </div>
    <div>
      <label
        for="correo"
        class="text-charcoal mb-2 block text-xs font-medium tracking-widest uppercase"
        >{f.emailLabel}</label
      >
      <input
        type="email"
        id="correo"
        name="correo"
        required
        autocomplete="email"
        class="focus:border-gold text-charcoal w-full border-b-2 border-gray-200 bg-transparent py-2 placeholder-gray-300 transition-colors outline-none"
        placeholder={f.emailPlaceholder}
      />
    </div>
    <div>
      <label
        for="telefono"
        class="text-charcoal mb-2 block text-xs font-medium tracking-widest uppercase"
        >{f.phoneLabel}</label
      >
      <input
        type="tel"
        id="telefono"
        name="telefono"
        autocomplete="tel"
        class="focus:border-gold text-charcoal w-full border-b-2 border-gray-200 bg-transparent py-2 placeholder-gray-300 transition-colors outline-none"
        placeholder={f.phonePlaceholder}
      />
    </div>
    {
      showDate && (
        <div>
          <label
            for="fecha"
            class="text-charcoal mb-2 block text-xs font-medium tracking-widest uppercase"
          >
            {f.dateLabel}
          </label>
          <input
            type="date"
            id="fecha"
            name="fecha"
            class="focus:border-gold text-charcoal w-full border-b-2 border-gray-200 bg-transparent py-2 transition-colors outline-none"
          />
        </div>
      )
    }
  </div>

  <div class="mb-8">
    <label
      for="mensaje"
      class="text-charcoal mb-2 block text-xs font-medium tracking-widest uppercase"
      >{f.messageLabel}</label
    >
    <textarea
      id="mensaje"
      name="mensaje"
      rows="5"
      required
      class="focus:border-gold text-charcoal w-full resize-none border-b-2 border-gray-200 bg-transparent py-2 placeholder-gray-300 transition-colors outline-none"
      placeholder={f.messagePlaceholder}></textarea>
  </div>

  <button
    type="submit"
    class="bg-gold hover:bg-charcoal cursor-pointer px-10 py-3 text-xs font-medium tracking-widest text-white uppercase transition-colors duration-300"
  >
    {submitLabel ?? f.submitLabel}
  </button>
</form>
