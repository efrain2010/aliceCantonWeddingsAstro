---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { getLang, getPageKey, routes } from "../i18n/index";
import { ADDRESS, CONTACT, SOCIAL, phoneInternational } from "../config/site";
import latoRegularUrl from "@fontsource/lato/files/lato-latin-400-normal.woff2?url";
import playfairBoldUrl from "@fontsource/playfair-display/files/playfair-display-latin-700-normal.woff2?url";

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageWidth?: number;
  imageHeight?: number;
}

const {
  title,
  description = "Alice Cantón Wedding Planner en Mérida Yucatán — organización de bodas y eventos desde 2014.",
  image = "/images/wedding-ceremony-merida-og.jpg",
  imageWidth = 1920,
  imageHeight = 1009,
} = Astro.props;

const lang = getLang(Astro.url.pathname);
const pageKey = getPageKey(Astro.url.pathname);
const pageTitle = `${title} | Alice Cantón Wedding Planner`;
const ogLocale = lang === "es" ? "es_MX" : "en_US";

const withTrailingSlash = (path: string) =>
  path.endsWith("/") ? path : `${path}/`;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);
const esURL = new URL(withTrailingSlash(routes.es[pageKey]), Astro.site);
const enURL = new URL(withTrailingSlash(routes.en[pageKey]), Astro.site);

const businessSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: "Alice Cantón Wedding Planner",
  image: imageURL.toString(),
  url: new URL("/", Astro.site).toString(),
  telephone: phoneInternational,
  email: CONTACT.email,
  description:
    "Wedding and event planning for destination weddings in Mérida and across the Yucatán Peninsula, Mexico.",
  address: {
    "@type": "PostalAddress",
    ...ADDRESS,
  },
  areaServed: {
    "@type": "Place",
    name: "Yucatán Peninsula, Mexico",
  },
  sameAs: [SOCIAL.facebook, SOCIAL.instagram],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <script
      data-page-key={pageKey}
      data-routes={JSON.stringify(routes)}
      id="lang-redirect"
      is:inline
    >
      (function () {
        try {
          var STORAGE_KEY = "lang-redirect-checked";
          if (localStorage.getItem(STORAGE_KEY)) return;
          localStorage.setItem(STORAGE_KEY, "1");

          var el = document.getElementById("lang-redirect");
          var pageKey = el.getAttribute("data-page-key");
          var routes = JSON.parse(el.getAttribute("data-routes"));
          var currentLang = document.documentElement.lang;

          var languages =
            navigator.languages && navigator.languages.length
              ? navigator.languages
              : [navigator.language || ""];

          var targetLang = null;
          for (var i = 0; i < languages.length; i++) {
            var code = (languages[i] || "").toLowerCase().slice(0, 2);
            if (code === "en" || code === "es") {
              targetLang = code;
              break;
            }
          }

          if (!targetLang || targetLang === currentLang) return;

          var targetPath = routes[targetLang] && routes[targetLang][pageKey];
          if (targetPath && targetPath !== window.location.pathname) {
            window.location.replace(
              targetPath + window.location.search + window.location.hash,
            );
          }
        } catch (e) {}
      })();
    </script>
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <meta content="index, follow" name="robots" />
    <meta content="#C9A96E" name="theme-color" />
    <meta content={description} name="description" />
    <title>{pageTitle}</title>
    <link
      as="font"
      crossorigin
      href={latoRegularUrl}
      rel="preload"
      type="font/woff2"
    />
    <link
      as="font"
      crossorigin
      href={playfairBoldUrl}
      rel="preload"
      type="font/woff2"
    />
    <link
      href="/images/favicon-150.png"
      rel="icon"
      sizes="150x150"
      type="image/png"
    />
    <link
      href="/images/favicon.png"
      rel="icon"
      sizes="184x184"
      type="image/png"
    />
    <link href="/images/favicon.png" rel="apple-touch-icon" />
    <meta content="/images/favicon.png" name="msapplication-TileImage" />
    <link href={canonicalURL} rel="canonical" />
    <link href={esURL} hreflang="es" rel="alternate" />
    <link href={enURL} hreflang="en" rel="alternate" />
    <link href={esURL} hreflang="x-default" rel="alternate" />

    <meta content="website" property="og:type" />
    <meta content="Alice Cantón Wedding Planner" property="og:site_name" />
    <meta content={ogLocale} property="og:locale" />
    <meta content={pageTitle} property="og:title" />
    <meta content={description} property="og:description" />
    <meta content={canonicalURL} property="og:url" />
    <meta content={imageURL} property="og:image" />
    <meta content={imageWidth.toString()} property="og:image:width" />
    <meta content={imageHeight.toString()} property="og:image:height" />

    <meta content="summary_large_image" name="twitter:card" />
    <meta content={pageTitle} name="twitter:title" />
    <meta content={description} name="twitter:description" />
    <meta content={imageURL} name="twitter:image" />

    <script
      is:inline
      set:html={JSON.stringify(businessSchema)}
      type="application/ld+json"
    />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
